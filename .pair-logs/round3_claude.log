{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kj2Ey1qYPX7RYqjg3JTVYY","type":"tool_result","content":"1\t// ═══════════════════════════════════════\n2\t// GOKKO Ad Pricing Simulator — Shared Logic\n3\t// ═══════════════════════════════════════\n4\t(function (window) {\n5\t'use strict';\n6\t\n7\t// ── PLAN DATA — 4 plans × 5 coefficient categories ──\n8\tconst PLANS = [\n9\t  // ── PLAN 0: ライトプラン（フック重視）──\n10\t  {\n11\t    name: 'ライトプラン',\n12\t    nameEn: 'LIGHT',\n13\t    period: [\n14\t      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n15\t      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n16\t      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n17\t      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n18\t      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n19\t      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n20\t    ],\n21\t    competition: [\n22\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n23\t      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n24\t      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n25\t      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n26\t    ],\n27\t    industry: [\n28\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n29\t      { label: '食品・飲料',           coeff: 1.1, desc: '頻繁な広告展開が想定' },\n30\t      { label: '化粧品・美容',         coeff: 1.3, desc: 'イメージ重視で高額予算' },\n31\t      { label: '金融・保険',           coeff: 1.6, desc: '規制業界で慎重な選定が必要' },\n32\t      { label: '医療・薬品',           coeff: 1.8, desc: '最高レベルの信頼性が要求' },\n33\t      { label: 'アルコール・ギャンブル', coeff: 2.0, desc: '特殊な規制対象業界' },\n34\t    ],\n35\t    media: [\n36\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n37\t      { label: 'Instagram',           coeff: 0.15, desc: 'TikTokに加算' },\n38\t      { label: 'YouTube（Short含む）', coeff: 0.2,  desc: 'TikTokに加算' },\n39\t      { label: 'X（旧Twitter）',       coeff: 0.1,  desc: 'TikTokに加算' },\n40\t      { label: 'LINE VOOM',           coeff: 0.1,  desc: 'TikTokに加算' },\n41\t      { label: 'バナー（静止画）',     coeff: 0.05, desc: 'TikTokに加算' },\n42\t      { label: 'Web広告（HP埋込等）',  coeff: 0.25, desc: 'TikTokに加算' },\n43\t      { label: 'テレビCM',            coeff: 0.4,  desc: 'TikTokに加算' },\n44\t    ],\n45\t    mediaCap: 1.8,\n46\t  },\n47\t  // ── PLAN 1: ベーシックプラン（実稼働費回収）──\n48\t  {\n49\t    name: 'ベーシックプラン',\n50\t    nameEn: 'BASIC',\n51\t    period: [\n52\t      { label: '1ヶ月', coeff: 1.0, desc: 'お試し配信' },\n53\t      { label: '3ヶ月', coeff: 1.2, desc: '短期集中キャンペーン' },\n54\t      { label: '6ヶ月', coeff: 1.6, desc: '標準的な広告契約' },\n55\t      { label: '1年',   coeff: 2.4, desc: '年間継続展開' },\n56\t      { label: '2年',   coeff: 3.6, desc: '長期ブランド戦略' },\n57\t      { label: '無期限', coeff: 4.8, desc: '恒久的な利用権' },\n58\t    ],\n59\t    competition: [\n60\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n61\t      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n62\t      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n63\t      { label: '全競合排除',   coeff: 2.4, desc: 'すべての競合を排除' },\n64\t    ],\n65\t    industry: [\n66\t      { label: '一般消費財',           coeff: 1.0,  desc: '標準的な広告予算規模' },\n67\t      { label: '食品・飲料',           coeff: 1.15, desc: '頻繁な広告展開が想定' },\n68\t      { label: '化粧品・美容',         coeff: 1.4,  desc: 'イメージ重視で高額予算' },\n69\t      { label: '金融・保険',           coeff: 1.7,  desc: '規制業界で慎重な選定が必要' },\n70\t      { label: '医療・薬品',           coeff: 1.9,  desc: '最高レベルの信頼性が要求' },\n71\t      { label: 'アルコール・ギャンブル', coeff: 2.1,  desc: '特殊な規制対象業界' },\n72\t    ],\n73\t    media: [\n74\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n75\t      { label: 'Instagram',           coeff: 0.17, desc: 'TikTokに加算' },\n76\t      { label: 'YouTube（Short含む）', coeff: 0.22, desc: 'TikTokに加算' },\n77\t      { label: 'X（旧Twitter）',       coeff: 0.12, desc: 'TikTokに加算' },\n78\t      { label: 'LINE VOOM',           coeff: 0.12, desc: 'TikTokに加算' },\n79\t      { label: 'バナー（静止画）',     coeff: 0.06, desc: 'TikTokに加算' },\n80\t      { label: 'Web広告（HP埋込等）',  coeff: 0.27, desc: 'TikTokに加算' },\n81\t      { label: 'テレビCM',            coeff: 0.44, desc: 'TikTokに加算' },\n82\t    ],\n83\t    mediaCap: 1.9,\n84\t  },\n85\t  // ── PLAN 2: スタンダードプラン（バランス）──\n86\t  {\n87\t    name: 'スタンダードプラン',\n88\t    nameEn: 'STANDARD',\n89\t    period: [\n90\t      { label: '1ヶ月', coeff: 1.2, desc: 'お試し配信' },\n91\t      { label: '3ヶ月', coeff: 1.5, desc: '短期集中キャンペーン' },\n92\t      { label: '6ヶ月', coeff: 2.0, desc: '標準的な広告契約' },\n93\t      { label: '1年',   coeff: 3.0, desc: '年間継続展開' },\n94\t      { label: '2年',   coeff: 4.5, desc: '長期ブランド戦略' },\n95\t      { label: '無期限', coeff: 6.0, desc: '恒久的な利用権' },\n96\t    ],\n97\t    competition: [\n98\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n99\t      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n100\t      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n101\t      { label: '全競合排除',   coeff: 2.5, desc: 'すべての競合を排除' },\n102\t    ],\n103\t    industry: [\n104\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n105\t      { label: '食品・飲料',           coeff: 1.2, desc: '頻繁な広告展開が想定' },\n106\t      { label: '化粧品・美容',         coeff: 1.5, desc: 'イメージ重視で高額予算' },\n107\t      { label: '金融・保険',           coeff: 1.8, desc: '規制業界で慎重な選定が必要' },\n108\t      { label: '医療・薬品',           coeff: 2.0, desc: '最高レベルの信頼性が要求' },\n109\t      { label: 'アルコール・ギャンブル', coeff: 2.2, desc: '特殊な規制対象業界' },\n110\t    ],\n111\t    media: [\n112\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n113\t      { label: 'Instagram',           coeff: 0.18, desc: 'TikTokに加算' },\n114\t      { label: 'YouTube（Short含む）', coeff: 0.25, desc: 'TikTokに加算' },\n115\t      { label: 'X（旧Twitter）',       coeff: 0.15, desc: 'TikTokに加算' },\n116\t      { label: 'LINE VOOM',           coeff: 0.15, desc: 'TikTokに加算' },\n117\t      { label: 'バナー（静止画）',     coeff: 0.07, desc: 'TikTokに加算' },\n118\t      { label: 'Web広告（HP埋込等）',  coeff: 0.3,  desc: 'TikTokに加算' },\n119\t      { label: 'テレビCM',            coeff: 0.45, desc: 'TikTokに加算' },\n120\t    ],\n121\t    mediaCap: 2.0,\n122\t  },\n123\t  // ── PLAN 3: プレミアムプラン（アップセル）──\n124\t  {\n125\t    name: 'プレミアムプラン',\n126\t    nameEn: 'PREMIUM',\n127\t    period: [\n128\t      { label: '1ヶ月', coeff: 1.5, desc: 'お試し配信' },\n129\t      { label: '3ヶ月', coeff: 1.8, desc: '短期集中キャンペーン' },\n130\t      { label: '6ヶ月', coeff: 2.4, desc: '標準的な広告契約' },\n131\t      { label: '1年',   coeff: 3.6, desc: '年間継続展開' },\n132\t      { label: '2年',   coeff: 5.4, desc: '長期ブランド戦略' },\n133\t      { label: '無期限', coeff: 7.2, desc: '恒久的な利用権' },\n134\t    ],\n135\t    competition: [\n136\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n137\t      { label: '商品競合のみ', coeff: 2.0, desc: '同一商品カテゴリを排除' },\n138\t      { label: '業界競合',     coeff: 2.5, desc: '同一業界全体を排除' },\n139\t      { label: '全競合排除',   coeff: 3.0, desc: 'すべての競合を排除' },\n140\t    ],\n141\t    industry: [\n142\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n143\t      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n144\t      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n145\t      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n146\t      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n147\t      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n148\t    ],\n149\t    media: [\n150\t      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n151\t      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n152\t      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n153\t      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n154\t      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n155\t      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n156\t      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n157\t      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n158\t    ],\n159\t    mediaCap: 3.0,\n160\t  },\n161\t];\n162\t\n163\t// GOKKO Margin is shared across all plans (3 tiers)\n164\tconst MARGIN = [\n165\t  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n166\t  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n167\t  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n168\t];\n169\t\n170\t// Talent rank is shared across all plans\n171\tconst RANK = [\n172\t  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n173\t  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n174\t  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n175\t  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n176\t  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n177\t  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n178\t  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n179\t  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n180\t];\n181\t\n182\t// ═══════════════════════════════════════\n183\t// STATE\n184\t// ═══════════════════════════════════════\n185\tlet currentPlan = 2; // default: スタンダード\n186\tconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n187\tlet simulatorInitialized = false;\n188\tconst REQUIRED_SIMULATOR_IDS = ['baseFee', 'coeffGrid', 'resultPlanBadge', 'resultBreakdown', 'resultValue', 'resultLiveRegion'];\n189\t\n190\t// ═══════════════════════════════════════\n191\t// YEAR SYNC\n192\t// ═══════════════════════════════════════\n193\tfunction syncCurrentYear() {\n194\t  const y = String(new Date().getFullYear());\n195\t  document.querySelectorAll('.copyright-year').forEach(el => { el.textContent = y; });\n196\t  document.querySelectorAll('.menu-year').forEach(el => { el.textContent = y; });\n197\t}\n198\t\n199\tfunction hasRequiredSimulatorMarkup() {\n200\t  return REQUIRED_SIMULATOR_IDS.every(id => document.getElementById(id));\n201\t}\n202\t\n203\tfunction resetSelections() {\n204\t  state.period = 0;\n205\t  state.competition = 0;\n206\t  state.industry = 0;\n207\t  state.media = [0];\n208\t  state.rank = 0;\n209\t  state.margin = 0;\n210\t}\n211\t\n212\t// ═══════════════════════════════════════\n213\t// PLAN SELECTOR\n214\t// ═══════════════════════════════════════\n215\tfunction selectPlan(btn) {\n216\t  currentPlan = parseInt(btn.dataset.plan, 10);\n217\t  document.querySelectorAll('.plan-btn').forEach(b => {\n218\t    b.classList.remove('active');\n219\t    b.setAttribute('aria-checked', 'false');\n220\t    b.setAttribute('tabindex', '-1');\n221\t  });\n222\t  btn.classList.add('active');\n223\t  btn.setAttribute('aria-checked', 'true');\n224\t  btn.setAttribute('tabindex', '0');\n225\t  btn.focus();\n226\t  resetSelections();\n227\t  renderCards();\n228\t  calculate();\n229\t}\n230\t\n231\t// ═══════════════════════════════════════\n232\t// RENDER\n233\t// ═══════════════════════════════════════\n234\tfunction getCoeffCategories() {\n235\t  const plan = PLANS[currentPlan];\n236\t  return [\n237\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n238\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n239\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n240\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n241\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n242\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n243\t  ];\n244\t}\n245\t\n246\tfunction renderCards() {\n247\t  const grid = document.getElementById('coeffGrid');\n248\t  if (!grid) return;\n249\t  grid.innerHTML = '';\n250\t  const cats = getCoeffCategories();\n251\t\n252\t  cats.forEach(cat => {\n253\t    const card = document.createElement('div');\n254\t    card.className = 'coeff-card';\n255\t    const isCheck = cat.type === 'checkbox';\n256\t\n257\t    let html = '';\n258\t    cat.options.forEach((opt, i) => {\n259\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n260\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n261\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `\\u00d7${opt.coeff}`;\n262\t      const role = isCheck ? 'checkbox' : 'radio';\n263\t      const ariaChecked = sel ? 'true' : 'false';\n264\t      const ariaDisabled = opt.base ? 'true' : 'false';\n265\t      const tabIndex = opt.base ? '-1' : '0';\n266\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n267\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n268\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n269\t    });\n270\t\n271\t    const capNote = cat.cap ? `<div class=\"media-note\">\\u203b \\u52a0\\u7b97\\u5408\\u8a08\\u306e\\u4e0a\\u9650\\uff08Cap\\uff09: \\u00d7${cat.cap}</div>` : '';\n272\t    const groupRole = isCheck ? 'group' : 'radiogroup';\n273\t\n274\t    card.innerHTML = `<div class=\"coeff-header\">\n275\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n276\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n277\t\n278\t    grid.appendChild(card);\n279\t  });\n280\t\n281\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n282\t    el.addEventListener('click', handleClick);\n283\t    el.addEventListener('keydown', (e) => {\n284\t      if (e.key === 'Enter' || e.key === ' ') {\n285\t        e.preventDefault();\n286\t        handleClick(e);\n287\t      }\n288\t    });\n289\t  });\n290\t}\n291\t\n292\tfunction handleClick(e) {\n293\t  const el = e.currentTarget;\n294\t  const catId = el.dataset.cat;\n295\t  const idx = parseInt(el.dataset.idx, 10);\n296\t  const cats = getCoeffCategories();\n297\t  const cat = cats.find(c => c.id === catId);\n298\t  if (!cat) return;\n299\t\n300\t  if (cat.type === 'checkbox') {\n301\t    if (el.dataset.base) return;\n302\t    const a = state[catId];\n303\t    const p = a.indexOf(idx);\n304\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n305\t  } else {\n306\t    state[catId] = idx;\n307\t  }\n308\t  renderCards();\n309\t  calculate();\n310\t}\n311\t\n312\t// ═══════════════════════════════════════\n313\t// CALCULATE\n314\t// ═══════════════════════════════════════\n315\tfunction calculate() {\n316\t  const baseFeeInput = document.getElementById('baseFee');\n317\t  const resultPlanBadge = document.getElementById('resultPlanBadge');\n318\t  const resultBreakdown = document.getElementById('resultBreakdown');\n319\t  const resultValue = document.getElementById('resultValue');\n320\t  const resultLiveRegion = document.getElementById('resultLiveRegion');\n321\t  if (!baseFeeInput || !resultPlanBadge || !resultBreakdown || !resultValue || !resultLiveRegion) return;\n322\t\n323\t  const plan = PLANS[currentPlan];\n324\t  const baseFee = parseInt(baseFeeInput.value.replace(/[^0-9]/g, ''), 10) || 0;\n325\t\n326\t  const pCoeff = (plan.period[state.period] || plan.period[0]).coeff;\n327\t  const cCoeff = (plan.competition[state.competition] || plan.competition[0]).coeff;\n328\t  const iCoeff = (plan.industry[state.industry] || plan.industry[0]).coeff;\n329\t\n330\t  let mSum = 0;\n331\t  state.media.forEach(i => { if (plan.media[i]) mSum += plan.media[i].coeff; });\n332\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n333\t\n334\t  const rCoeff = (RANK[state.rank] || RANK[0]).coeff;\n335\t  const marginCoeff = (MARGIN[state.margin] || MARGIN[0]).coeff;\n336\t\n337\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n338\t\n339\t  resultPlanBadge.textContent = plan.nameEn;\n340\t\n341\t  const chips = [\n342\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n343\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n344\t  ];\n345\t  resultBreakdown.innerHTML = chips.map((c, i) =>\n346\t    `<span class=\"result-chip\">${c.l} <span>\\u00d7${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">\\u00d7</span>' : ''}`\n347\t  ).join('');\n348\t\n349\t  const formattedTotal = '\\u00a5' + Math.round(total).toLocaleString('ja-JP');\n350\t  resultValue.textContent = formattedTotal;\n351\t  resultLiveRegion.textContent =\n352\t    `${plan.name}\\u3001\\u898b\\u7a4d\\u7dcf\\u984d ${formattedTotal}\\u3002\\u671f\\u9593 ${pCoeff}\\u3001\\u7af6\\u5408 ${cCoeff}\\u3001\\u696d\\u754c ${iCoeff}\\u3001\\u30e1\\u30c7\\u30a3\\u30a2 ${mCoeff}\\u3001\\u30e9\\u30f3\\u30af ${rCoeff}\\u3001\\u30de\\u30fc\\u30b8\\u30f3 ${marginCoeff}\\u3002`;\n353\t}\n354\t\n355\t// ═══════════════════════════════════════\n356\t// INIT\n357\t// ═══════════════════════════════════════\n358\tfunction initSimulator() {\n359\t  if (simulatorInitialized) return true;\n360\t  if (!hasRequiredSimulatorMarkup()) {\n361\t    console.warn('Simulator markup is incomplete. Skipping initialization.');\n362\t    return false;\n363\t  }\n364\t\n365\t  // Plan selector — roving tabindex + arrow key navigation (WAI-ARIA radiogroup)\n366\t  const planBtns = Array.from(document.querySelectorAll('.plan-btn'));\n367\t  planBtns.forEach((btn, idx) => {\n368\t    btn.setAttribute('tabindex', btn.classList.contains('active') ? '0' : '-1');\n369\t    btn.addEventListener('click', () => selectPlan(btn));\n370\t    btn.addEventListener('keydown', (e) => {\n371\t      if (e.key === 'Enter' || e.key === ' ') {\n372\t        e.preventDefault();\n373\t        selectPlan(btn);\n374\t        return;\n375\t      }\n376\t      let target;\n377\t      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n378\t        target = planBtns[(idx + 1) % planBtns.length];\n379\t      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n380\t        target = planBtns[(idx - 1 + planBtns.length) % planBtns.length];\n381\t      } else if (e.key === 'Home') {\n382\t        target = planBtns[0];\n383\t      } else if (e.key === 'End') {\n384\t        target = planBtns[planBtns.length - 1];\n385\t      }\n386\t      if (target) {\n387\t        e.preventDefault();\n388\t        selectPlan(target);\n389\t      }\n390\t    });\n391\t  });\n392\t\n393\t  // Base fee input formatting\n394\t  document.getElementById('baseFee').addEventListener('input', function() {\n395\t    const raw = this.value.replace(/[^0-9]/g, '');\n396\t    this.value = raw ? parseInt(raw, 10).toLocaleString('ja-JP') : '';\n397\t    calculate();\n398\t  });\n399\t\n400\t  // Dynamic year\n401\t  syncCurrentYear();\n402\t\n403\t  // Initial render\n404\t  simulatorInitialized = true;\n405\t  renderCards();\n406\t  calculate();\n407\t  console.log('\\u2705 \\u521d\\u671f\\u5316\\u5b8c\\u4e86: \\u30ab\\u30fc\\u30c9\\u6570 =', document.querySelectorAll('.coeff-card').length);\n408\t  return true;\n409\t}\n410\t\n411\t// Expose public API\n412\twindow.initSimulator = initSimulator;\n413\t\n414\t})(window);\n415\t"}]},"parent_tool_use_id":null,"session_id":"4f56240e-2691-4800-9410-03f508b591f5","uuid":"9b457b17-6f9f-4863-84b3-c7c88abfeded","timestamp":"2026-04-09T09:50:46.444Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ucmuller/workspace/cast-simulation/shared.js","content":"// ═══════════════════════════════════════\n// GOKKO Ad Pricing Simulator — Shared Logic\n// ═══════════════════════════════════════\n(function (window) {\n'use strict';\n\n// ── PLAN DATA — 4 plans × 5 coefficient categories ──\nconst PLANS = [\n  // ── PLAN 0: ライトプラン（フック重視）──\n  {\n    name: 'ライトプラン',\n    nameEn: 'LIGHT',\n    period: [\n      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.1, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.3, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.6, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.8, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.2,  desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.1,  desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.1,  desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.05, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.25, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.4,  desc: 'TikTokに加算' },\n    ],\n    mediaCap: 1.8,\n  },\n  // ── PLAN 1: ベーシックプラン（実稼働費回収）──\n  {\n    name: 'ベーシックプラン',\n    nameEn: 'BASIC',\n    period: [\n      { label: '1ヶ月', coeff: 1.0, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.2, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 1.6, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 2.4, desc: '年間継続展開' },\n      { label: '2年',   coeff: 3.6, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 4.8, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.4, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0,  desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.15, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.4,  desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.7,  desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.9,  desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.1,  desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.17, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.22, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.12, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.12, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.06, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.27, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.44, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 1.9,\n  },\n  // ── PLAN 2: スタンダードプラン（バランス）──\n  {\n    name: 'スタンダードプラン',\n    nameEn: 'STANDARD',\n    period: [\n      { label: '1ヶ月', coeff: 1.2, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.5, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 2.0, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 3.0, desc: '年間継続展開' },\n      { label: '2年',   coeff: 4.5, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 6.0, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.5, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.2, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.5, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.8, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.0, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.2, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.18, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.25, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.07, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.3,  desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.45, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 2.0,\n  },\n  // ── PLAN 3: プレミアムプラン（アップセル）──\n  {\n    name: 'プレミアムプラン',\n    nameEn: 'PREMIUM',\n    period: [\n      { label: '1ヶ月', coeff: 1.5, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.8, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 2.4, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 3.6, desc: '年間継続展開' },\n      { label: '2年',   coeff: 5.4, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 7.2, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 2.0, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.5, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 3.0, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 3.0,\n  },\n];\n\n// GOKKO Margin is shared across all plans (3 tiers)\nconst MARGIN = [\n  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n];\n\n// Talent rank is shared across all plans\nconst RANK = [\n  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n];\n\n// ═══════════════════════════════════════\n// STATE\n// ═══════════════════════════════════════\nlet currentPlan = 2; // default: スタンダード\nconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\nlet simulatorInitialized = false;\nconst REQUIRED_SIMULATOR_IDS = ['baseFee', 'coeffGrid', 'resultPlanBadge', 'resultBreakdown', 'resultValue', 'resultLiveRegion'];\n\n// ═══════════════════════════════════════\n// YEAR SYNC\n// ═══════════════════════════════════════\nfunction syncCurrentYear() {\n  const y = String(new Date().getFullYear());\n  document.querySelectorAll('.copyright-year').forEach(el => { el.textContent = y; });\n  document.querySelectorAll('.menu-year').forEach(el => { el.textContent = y; });\n}\n\nfunction hasRequiredSimulatorMarkup() {\n  return REQUIRED_SIMULATOR_IDS.every(id => document.getElementById(id));\n}\n\nfunction resetSelections() {\n  state.period = 0;\n  state.competition = 0;\n  state.industry = 0;\n  state.media = [0];\n  state.rank = 0;\n  state.margin = 0;\n}\n\n// ═══════════════════════════════════════\n// PLAN SELECTOR\n// ═══════════════════════════════════════\nfunction selectPlan(btn) {\n  currentPlan = parseInt(btn.dataset.plan, 10);\n  document.querySelectorAll('.plan-btn').forEach(b => {\n    b.classList.remove('active');\n    b.setAttribute('aria-checked', 'false');\n    b.setAttribute('tabindex', '-1');\n  });\n  btn.classList.add('active');\n  btn.setAttribute('aria-checked', 'true');\n  btn.setAttribute('tabindex', '0');\n  btn.focus();\n  resetSelections();\n  renderCards();\n  calculate();\n}\n\n// ═══════════════════════════════════════\n// RENDER\n// ═══════════════════════════════════════\nfunction getCoeffCategories() {\n  const plan = PLANS[currentPlan];\n  return [\n    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n  ];\n}\n\nfunction renderCards() {\n  const grid = document.getElementById('coeffGrid');\n  if (!grid) return;\n  grid.innerHTML = '';\n  const cats = getCoeffCategories();\n\n  cats.forEach(cat => {\n    const card = document.createElement('div');\n    card.className = 'coeff-card';\n    const isCheck = cat.type === 'checkbox';\n\n    let html = '';\n    cat.options.forEach((opt, i) => {\n      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `\\u00d7${opt.coeff}`;\n      const role = isCheck ? 'checkbox' : 'radio';\n      const ariaChecked = sel ? 'true' : 'false';\n      const ariaDisabled = opt.base ? 'true' : 'false';\n      const tabIndex = opt.base ? '-1' : '0';\n      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n        <div class=\"opt-coeff\">${cv}</div></div>`;\n    });\n\n    const capNote = cat.cap ? `<div class=\"media-note\">\\u203b \\u52a0\\u7b97\\u5408\\u8a08\\u306e\\u4e0a\\u9650\\uff08Cap\\uff09: \\u00d7${cat.cap}</div>` : '';\n    const groupRole = isCheck ? 'group' : 'radiogroup';\n\n    card.innerHTML = `<div class=\"coeff-header\">\n      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n\n    grid.appendChild(card);\n  });\n\n  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n    el.addEventListener('click', handleClick);\n    el.addEventListener('keydown', (e) => {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        handleClick(e);\n      }\n    });\n  });\n}\n\nfunction handleClick(e) {\n  const el = e.currentTarget;\n  const catId = el.dataset.cat;\n  const idx = parseInt(el.dataset.idx, 10);\n  const cats = getCoeffCategories();\n  const cat = cats.find(c => c.id === catId);\n  if (!cat) return;\n\n  if (cat.type === 'checkbox') {\n    if (el.dataset.base) return;\n    const a = state[catId];\n    const p = a.indexOf(idx);\n    p > -1 ? a.splice(p, 1) : a.push(idx);\n  } else {\n    state[catId] = idx;\n  }\n  renderCards();\n  calculate();\n}\n\n// ═══════════════════════════════════════\n// CALCULATE\n// ═══════════════════════════════════════\nfunction calculate() {\n  const baseFeeInput = document.getElementById('baseFee');\n  const resultPlanBadge = document.getElementById('resultPlanBadge');\n  const resultBreakdown = document.getElementById('resultBreakdown');\n  const resultValue = document.getElementById('resultValue');\n  const resultLiveRegion = document.getElementById('resultLiveRegion');\n  if (!baseFeeInput || !resultPlanBadge || !resultBreakdown || !resultValue || !resultLiveRegion) return;\n\n  const plan = PLANS[currentPlan];\n  const baseFee = parseInt(baseFeeInput.value.replace(/[^0-9]/g, ''), 10) || 0;\n\n  const pCoeff = (plan.period[state.period] || plan.period[0]).coeff;\n  const cCoeff = (plan.competition[state.competition] || plan.competition[0]).coeff;\n  const iCoeff = (plan.industry[state.industry] || plan.industry[0]).coeff;\n\n  let mSum = 0;\n  state.media.forEach(i => { if (plan.media[i]) mSum += plan.media[i].coeff; });\n  const mCoeff = Math.min(mSum, plan.mediaCap);\n\n  const rCoeff = (RANK[state.rank] || RANK[0]).coeff;\n  const marginCoeff = (MARGIN[state.margin] || MARGIN[0]).coeff;\n\n  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n\n  resultPlanBadge.textContent = plan.nameEn;\n\n  const chips = [\n    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n  ];\n  resultBreakdown.innerHTML = chips.map((c, i) =>\n    `<span class=\"result-chip\">${c.l} <span>\\u00d7${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">\\u00d7</span>' : ''}`\n  ).join('');\n\n  const formattedTotal = '\\u00a5' + Math.round(total).toLocaleString('ja-JP');\n  resultValue.textContent = formattedTotal;\n  resultLiveRegion.textContent =\n    `${plan.name}\\u3001\\u898b\\u7a4d\\u7dcf\\u984d ${formattedTotal}\\u3002\\u671f\\u9593 ${pCoeff}\\u3001\\u7af6\\u5408 ${cCoeff}\\u3001\\u696d\\u754c ${iCoeff}\\u3001\\u30e1\\u30c7\\u30a3\\u30a2 ${mCoeff}\\u3001\\u30e9\\u30f3\\u30af ${rCoeff}\\u3001\\u30de\\u30fc\\u30b8\\u30f3 ${marginCoeff}\\u3002`;\n}\n\n// ═══════════════════════════════════════\n// INIT\n// ═══════════════════════════════════════\nfunction initSimulator() {\n  if (simulatorInitialized) return true;\n  if (!hasRequiredSimulatorMarkup()) {\n    console.warn('Simulator markup is incomplete. Skipping initialization.');\n    return false;\n  }\n\n  // Plan selector — roving tabindex + arrow key navigation (WAI-ARIA radiogroup)\n  const planBtns = Array.from(document.querySelectorAll('.plan-btn'));\n  planBtns.forEach((btn, idx) => {\n    btn.setAttribute('tabindex', btn.classList.contains('active') ? '0' : '-1');\n    btn.addEventListener('click', () => selectPlan(btn));\n    btn.addEventListener('keydown', (e) => {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        selectPlan(btn);\n        return;\n      }\n      let target;\n      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n        target = planBtns[(idx + 1) % planBtns.length];\n      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n        target = planBtns[(idx - 1 + planBtns.length) % planBtns.length];\n      } else if (e.key === 'Home') {\n        target = planBtns[0];\n      } else if (e.key === 'End') {\n        target = planBtns[planBtns.length - 1];\n      }\n      if (target) {\n        e.preventDefault();\n        selectPlan(target);\n      }\n    });\n  });\n\n  // Base fee input formatting\n  document.getElementById('baseFee').addEventListener('input', function() {\n    const raw = this.value.replace(/[^0-9]/g, '');\n    this.value = raw ? parseInt(raw, 10).toLocaleString('ja-JP') : '';\n    calculate();\n  });\n\n  // Dynamic year\n  syncCurrentYear();\n\n  // Initial render\n  simulatorInitialized = true;\n  renderCards();\n  calculate();\n  console.log('\\u2705 \\u521d\\u671f\\u5316\\u5b8c\\u4e86: \\u30ab\\u30fc\\u30c9\\u6570 =', document.querySelectorAll('.coeff-card').length);\n  return true;\n}\n\n// Expose public API\nwindow.initSimulator = initSimulator;\n\n})(window);\n","numLines":415,"startLine":1,"totalLines":415}}}
