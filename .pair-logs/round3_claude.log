{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015WQwULvLU2zYGSW788qUcz","type":"tool_result","content":"1\t// ═══════════════════════════════════════\n2\t// GOKKO Ad Pricing Simulator — Shared Logic\n3\t// ═══════════════════════════════════════\n4\t\n5\t// ── PLAN DATA — 4 plans × 5 coefficient categories ──\n6\tconst PLANS = [\n7\t  // ── PLAN 0: ライトプラン（フック重視）──\n8\t  {\n9\t    name: 'ライトプラン',\n10\t    nameEn: 'LIGHT',\n11\t    period: [\n12\t      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n13\t      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n14\t      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n15\t      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n16\t      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n17\t      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n18\t    ],\n19\t    competition: [\n20\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n21\t      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n22\t      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n23\t      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n24\t    ],\n25\t    industry: [\n26\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n27\t      { label: '食品・飲料',           coeff: 1.1, desc: '頻繁な広告展開が想定' },\n28\t      { label: '化粧品・美容',         coeff: 1.3, desc: 'イメージ重視で高額予算' },\n29\t      { label: '金融・保険',           coeff: 1.6, desc: '規制業界で慎重な選定が必要' },\n30\t      { label: '医療・薬品',           coeff: 1.8, desc: '最高レベルの信頼性が要求' },\n31\t      { label: 'アルコール・ギャンブル', coeff: 2.0, desc: '特殊な規制対象業界' },\n32\t    ],\n33\t    media: [\n34\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n35\t      { label: 'Instagram',           coeff: 0.15, desc: 'TikTokに加算' },\n36\t      { label: 'YouTube（Short含む）', coeff: 0.2,  desc: 'TikTokに加算' },\n37\t      { label: 'X（旧Twitter）',       coeff: 0.1,  desc: 'TikTokに加算' },\n38\t      { label: 'LINE VOOM',           coeff: 0.1,  desc: 'TikTokに加算' },\n39\t      { label: 'バナー（静止画）',     coeff: 0.05, desc: 'TikTokに加算' },\n40\t      { label: 'Web広告（HP埋込等）',  coeff: 0.25, desc: 'TikTokに加算' },\n41\t      { label: 'テレビCM',            coeff: 0.4,  desc: 'TikTokに加算' },\n42\t    ],\n43\t    mediaCap: 1.8,\n44\t  },\n45\t  // ── PLAN 1: ベーシックプラン（実稼働費回収）──\n46\t  {\n47\t    name: 'ベーシックプラン',\n48\t    nameEn: 'BASIC',\n49\t    period: [\n50\t      { label: '1ヶ月', coeff: 1.0, desc: 'お試し配信' },\n51\t      { label: '3ヶ月', coeff: 1.2, desc: '短期集中キャンペーン' },\n52\t      { label: '6ヶ月', coeff: 1.6, desc: '標準的な広告契約' },\n53\t      { label: '1年',   coeff: 2.4, desc: '年間継続展開' },\n54\t      { label: '2年',   coeff: 3.6, desc: '長期ブランド戦略' },\n55\t      { label: '無期限', coeff: 4.8, desc: '恒久的な利用権' },\n56\t    ],\n57\t    competition: [\n58\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n59\t      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n60\t      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n61\t      { label: '全競合排除',   coeff: 2.4, desc: 'すべての競合を排除' },\n62\t    ],\n63\t    industry: [\n64\t      { label: '一般消費財',           coeff: 1.0,  desc: '標準的な広告予算規模' },\n65\t      { label: '食品・飲料',           coeff: 1.15, desc: '頻繁な広告展開が想定' },\n66\t      { label: '化粧品・美容',         coeff: 1.4,  desc: 'イメージ重視で高額予算' },\n67\t      { label: '金融・保険',           coeff: 1.7,  desc: '規制業界で慎重な選定が必要' },\n68\t      { label: '医療・薬品',           coeff: 1.9,  desc: '最高レベルの信頼性が要求' },\n69\t      { label: 'アルコール・ギャンブル', coeff: 2.1,  desc: '特殊な規制対象業界' },\n70\t    ],\n71\t    media: [\n72\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n73\t      { label: 'Instagram',           coeff: 0.17, desc: 'TikTokに加算' },\n74\t      { label: 'YouTube（Short含む）', coeff: 0.22, desc: 'TikTokに加算' },\n75\t      { label: 'X（旧Twitter）',       coeff: 0.12, desc: 'TikTokに加算' },\n76\t      { label: 'LINE VOOM',           coeff: 0.12, desc: 'TikTokに加算' },\n77\t      { label: 'バナー（静止画）',     coeff: 0.06, desc: 'TikTokに加算' },\n78\t      { label: 'Web広告（HP埋込等）',  coeff: 0.27, desc: 'TikTokに加算' },\n79\t      { label: 'テレビCM',            coeff: 0.44, desc: 'TikTokに加算' },\n80\t    ],\n81\t    mediaCap: 1.9,\n82\t  },\n83\t  // ── PLAN 2: スタンダードプラン（バランス）──\n84\t  {\n85\t    name: 'スタンダードプラン',\n86\t    nameEn: 'STANDARD',\n87\t    period: [\n88\t      { label: '1ヶ月', coeff: 1.2, desc: 'お試し配信' },\n89\t      { label: '3ヶ月', coeff: 1.5, desc: '短期集中キャンペーン' },\n90\t      { label: '6ヶ月', coeff: 2.0, desc: '標準的な広告契約' },\n91\t      { label: '1年',   coeff: 3.0, desc: '年間継続展開' },\n92\t      { label: '2年',   coeff: 4.5, desc: '長期ブランド戦略' },\n93\t      { label: '無期限', coeff: 6.0, desc: '恒久的な利用権' },\n94\t    ],\n95\t    competition: [\n96\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n97\t      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n98\t      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n99\t      { label: '全競合排除',   coeff: 2.5, desc: 'すべての競合を排除' },\n100\t    ],\n101\t    industry: [\n102\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n103\t      { label: '食品・飲料',           coeff: 1.2, desc: '頻繁な広告展開が想定' },\n104\t      { label: '化粧品・美容',         coeff: 1.5, desc: 'イメージ重視で高額予算' },\n105\t      { label: '金融・保険',           coeff: 1.8, desc: '規制業界で慎重な選定が必要' },\n106\t      { label: '医療・薬品',           coeff: 2.0, desc: '最高レベルの信頼性が要求' },\n107\t      { label: 'アルコール・ギャンブル', coeff: 2.2, desc: '特殊な規制対象業界' },\n108\t    ],\n109\t    media: [\n110\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n111\t      { label: 'Instagram',           coeff: 0.18, desc: 'TikTokに加算' },\n112\t      { label: 'YouTube（Short含む）', coeff: 0.25, desc: 'TikTokに加算' },\n113\t      { label: 'X（旧Twitter）',       coeff: 0.15, desc: 'TikTokに加算' },\n114\t      { label: 'LINE VOOM',           coeff: 0.15, desc: 'TikTokに加算' },\n115\t      { label: 'バナー（静止画）',     coeff: 0.07, desc: 'TikTokに加算' },\n116\t      { label: 'Web広告（HP埋込等）',  coeff: 0.3,  desc: 'TikTokに加算' },\n117\t      { label: 'テレビCM',            coeff: 0.45, desc: 'TikTokに加算' },\n118\t    ],\n119\t    mediaCap: 2.0,\n120\t  },\n121\t  // ── PLAN 3: プレミアムプラン（アップセル）──\n122\t  {\n123\t    name: 'プレミアムプラン',\n124\t    nameEn: 'PREMIUM',\n125\t    period: [\n126\t      { label: '1ヶ月', coeff: 1.5, desc: 'お試し配信' },\n127\t      { label: '3ヶ月', coeff: 1.8, desc: '短期集中キャンペーン' },\n128\t      { label: '6ヶ月', coeff: 2.4, desc: '標準的な広告契約' },\n129\t      { label: '1年',   coeff: 3.6, desc: '年間継続展開' },\n130\t      { label: '2年',   coeff: 5.4, desc: '長期ブランド戦略' },\n131\t      { label: '無期限', coeff: 7.2, desc: '恒久的な利用権' },\n132\t    ],\n133\t    competition: [\n134\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n135\t      { label: '商品競合のみ', coeff: 2.0, desc: '同一商品カテゴリを排除' },\n136\t      { label: '業界競合',     coeff: 2.5, desc: '同一業界全体を排除' },\n137\t      { label: '全競合排除',   coeff: 3.0, desc: 'すべての競合を排除' },\n138\t    ],\n139\t    industry: [\n140\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n141\t      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n142\t      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n143\t      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n144\t      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n145\t      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n146\t    ],\n147\t    media: [\n148\t      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n149\t      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n150\t      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n151\t      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n152\t      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n153\t      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n154\t      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n155\t      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n156\t    ],\n157\t    mediaCap: 3.0,\n158\t  },\n159\t];\n160\t\n161\t// GOKKO Margin is shared across all plans (3 tiers)\n162\tconst MARGIN = [\n163\t  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n164\t  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n165\t  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n166\t];\n167\t\n168\t// Talent rank is shared across all plans\n169\tconst RANK = [\n170\t  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n171\t  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n172\t  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n173\t  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n174\t  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n175\t  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n176\t  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n177\t  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n178\t];\n179\t\n180\t// ═══════════════════════════════════════\n181\t// STATE\n182\t// ═══════════════════════════════════════\n183\tlet currentPlan = 2; // default: スタンダード\n184\tconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n185\tlet simulatorInitialized = false;\n186\tconst REQUIRED_SIMULATOR_IDS = ['baseFee', 'coeffGrid', 'resultPlanBadge', 'resultBreakdown', 'resultValue', 'resultLiveRegion'];\n187\t\n188\t// ═══════════════════════════════════════\n189\t// YEAR SYNC\n190\t// ═══════════════════════════════════════\n191\tfunction syncCurrentYear() {\n192\t  const y = String(new Date().getFullYear());\n193\t  document.querySelectorAll('.copyright-year').forEach(el => { el.textContent = y; });\n194\t  document.querySelectorAll('.menu-year').forEach(el => { el.textContent = y; });\n195\t}\n196\t\n197\tfunction hasRequiredSimulatorMarkup() {\n198\t  return REQUIRED_SIMULATOR_IDS.every(id => document.getElementById(id));\n199\t}\n200\t\n201\tfunction resetSelections() {\n202\t  state.period = 0;\n203\t  state.competition = 0;\n204\t  state.industry = 0;\n205\t  state.media = [0];\n206\t  state.rank = 0;\n207\t  state.margin = 0;\n208\t}\n209\t\n210\t// ═══════════════════════════════════════\n211\t// PLAN SELECTOR\n212\t// ═══════════════════════════════════════\n213\tfunction selectPlan(btn) {\n214\t  currentPlan = parseInt(btn.dataset.plan, 10);\n215\t  document.querySelectorAll('.plan-btn').forEach(b => {\n216\t    b.classList.remove('active');\n217\t    b.setAttribute('aria-checked', 'false');\n218\t  });\n219\t  btn.classList.add('active');\n220\t  btn.setAttribute('aria-checked', 'true');\n221\t  resetSelections();\n222\t  renderCards();\n223\t  calculate();\n224\t}\n225\t\n226\t// ═══════════════════════════════════════\n227\t// RENDER\n228\t// ═══════════════════════════════════════\n229\tfunction getCoeffCategories() {\n230\t  const plan = PLANS[currentPlan];\n231\t  return [\n232\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n233\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n234\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n235\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n236\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n237\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n238\t  ];\n239\t}\n240\t\n241\tfunction renderCards() {\n242\t  const grid = document.getElementById('coeffGrid');\n243\t  if (!grid) return;\n244\t  grid.innerHTML = '';\n245\t  const cats = getCoeffCategories();\n246\t\n247\t  cats.forEach(cat => {\n248\t    const card = document.createElement('div');\n249\t    card.className = 'coeff-card';\n250\t    const isCheck = cat.type === 'checkbox';\n251\t\n252\t    let html = '';\n253\t    cat.options.forEach((opt, i) => {\n254\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n255\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n256\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `\\u00d7${opt.coeff}`;\n257\t      const role = isCheck ? 'checkbox' : 'radio';\n258\t      const ariaChecked = sel ? 'true' : 'false';\n259\t      const ariaDisabled = opt.base ? 'true' : 'false';\n260\t      const tabIndex = opt.base ? '-1' : '0';\n261\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n262\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n263\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n264\t    });\n265\t\n266\t    const capNote = cat.cap ? `<div class=\"media-note\">\\u203b \\u52a0\\u7b97\\u5408\\u8a08\\u306e\\u4e0a\\u9650\\uff08Cap\\uff09: \\u00d7${cat.cap}</div>` : '';\n267\t    const groupRole = isCheck ? 'group' : 'radiogroup';\n268\t\n269\t    card.innerHTML = `<div class=\"coeff-header\">\n270\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n271\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n272\t\n273\t    grid.appendChild(card);\n274\t  });\n275\t\n276\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n277\t    el.addEventListener('click', handleClick);\n278\t    el.addEventListener('keydown', (e) => {\n279\t      if (e.key === 'Enter' || e.key === ' ') {\n280\t        e.preventDefault();\n281\t        handleClick(e);\n282\t      }\n283\t    });\n284\t  });\n285\t}\n286\t\n287\tfunction handleClick(e) {\n288\t  const el = e.currentTarget;\n289\t  const catId = el.dataset.cat;\n290\t  const idx = parseInt(el.dataset.idx, 10);\n291\t  const cats = getCoeffCategories();\n292\t  const cat = cats.find(c => c.id === catId);\n293\t  if (!cat) return;\n294\t\n295\t  if (cat.type === 'checkbox') {\n296\t    if (el.dataset.base) return;\n297\t    const a = state[catId];\n298\t    const p = a.indexOf(idx);\n299\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n300\t  } else {\n301\t    state[catId] = idx;\n302\t  }\n303\t  renderCards();\n304\t  calculate();\n305\t}\n306\t\n307\t// ═══════════════════════════════════════\n308\t// CALCULATE\n309\t// ═══════════════════════════════════════\n310\tfunction calculate() {\n311\t  const baseFeeInput = document.getElementById('baseFee');\n312\t  const resultPlanBadge = document.getElementById('resultPlanBadge');\n313\t  const resultBreakdown = document.getElementById('resultBreakdown');\n314\t  const resultValue = document.getElementById('resultValue');\n315\t  const resultLiveRegion = document.getElementById('resultLiveRegion');\n316\t  if (!baseFeeInput || !resultPlanBadge || !resultBreakdown || !resultValue || !resultLiveRegion) return;\n317\t\n318\t  const plan = PLANS[currentPlan];\n319\t  const baseFee = parseInt(baseFeeInput.value.replace(/[^0-9]/g, ''), 10) || 0;\n320\t\n321\t  const pCoeff = plan.period[state.period].coeff;\n322\t  const cCoeff = plan.competition[state.competition].coeff;\n323\t  const iCoeff = plan.industry[state.industry].coeff;\n324\t\n325\t  let mSum = 0;\n326\t  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n327\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n328\t\n329\t  const rCoeff = RANK[state.rank].coeff;\n330\t  const marginCoeff = MARGIN[state.margin].coeff;\n331\t\n332\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n333\t\n334\t  resultPlanBadge.textContent = plan.nameEn;\n335\t\n336\t  const chips = [\n337\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n338\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n339\t  ];\n340\t  resultBreakdown.innerHTML = chips.map((c, i) =>\n341\t    `<span class=\"result-chip\">${c.l} <span>\\u00d7${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">\\u00d7</span>' : ''}`\n342\t  ).join('');\n343\t\n344\t  const formattedTotal = '\\u00a5' + Math.round(total).toLocaleString('ja-JP');\n345\t  resultValue.textContent = formattedTotal;\n346\t  resultLiveRegion.textContent =\n347\t    `${plan.name}\\u3001\\u898b\\u7a4d\\u7dcf\\u984d ${formattedTotal}\\u3002\\u671f\\u9593 ${pCoeff}\\u3001\\u7af6\\u5408 ${cCoeff}\\u3001\\u696d\\u754c ${iCoeff}\\u3001\\u30e1\\u30c7\\u30a3\\u30a2 ${mCoeff}\\u3001\\u30e9\\u30f3\\u30af ${rCoeff}\\u3001\\u30de\\u30fc\\u30b8\\u30f3 ${marginCoeff}\\u3002`;\n348\t}\n349\t\n350\t// ═══════════════════════════════════════\n351\t// INIT\n352\t// ═══════════════════════════════════════\n353\tfunction initSimulator() {\n354\t  if (simulatorInitialized) return true;\n355\t  if (!hasRequiredSimulatorMarkup()) {\n356\t    console.warn('Simulator markup is incomplete. Skipping initialization.');\n357\t    return false;\n358\t  }\n359\t\n360\t  // Plan selector events\n361\t  document.querySelectorAll('.plan-btn').forEach(btn => {\n362\t    btn.addEventListener('click', () => selectPlan(btn));\n363\t    btn.addEventListener('keydown', (e) => {\n364\t      if (e.key === 'Enter' || e.key === ' ') {\n365\t        e.preventDefault();\n366\t        selectPlan(btn);\n367\t      }\n368\t    });\n369\t  });\n370\t\n371\t  // Base fee input formatting\n372\t  document.getElementById('baseFee').addEventListener('input', function() {\n373\t    const raw = this.value.replace(/[^0-9]/g, '');\n374\t    this.value = raw ? parseInt(raw, 10).toLocaleString('ja-JP') : '';\n375\t    calculate();\n376\t  });\n377\t\n378\t  // Dynamic year\n379\t  syncCurrentYear();\n380\t\n381\t  // Initial render\n382\t  simulatorInitialized = true;\n383\t  renderCards();\n384\t  calculate();\n385\t  console.log('\\u2705 \\u521d\\u671f\\u5316\\u5b8c\\u4e86: \\u30ab\\u30fc\\u30c9\\u6570 =', document.querySelectorAll('.coeff-card').length);\n386\t  return true;\n387\t}\n388\t"}]},"parent_tool_use_id":null,"session_id":"4f56240e-2691-4800-9410-03f508b591f5","uuid":"69a67771-803c-4728-b740-be477b196ddc","timestamp":"2026-04-09T09:46:37.103Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ucmuller/workspace/cast-simulation/shared.js","content":"// ═══════════════════════════════════════\n// GOKKO Ad Pricing Simulator — Shared Logic\n// ═══════════════════════════════════════\n\n// ── PLAN DATA — 4 plans × 5 coefficient categories ──\nconst PLANS = [\n  // ── PLAN 0: ライトプラン（フック重視）──\n  {\n    name: 'ライトプラン',\n    nameEn: 'LIGHT',\n    period: [\n      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.1, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.3, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.6, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.8, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.2,  desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.1,  desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.1,  desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.05, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.25, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.4,  desc: 'TikTokに加算' },\n    ],\n    mediaCap: 1.8,\n  },\n  // ── PLAN 1: ベーシックプラン（実稼働費回収）──\n  {\n    name: 'ベーシックプラン',\n    nameEn: 'BASIC',\n    period: [\n      { label: '1ヶ月', coeff: 1.0, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.2, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 1.6, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 2.4, desc: '年間継続展開' },\n      { label: '2年',   coeff: 3.6, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 4.8, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.4, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0,  desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.15, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.4,  desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.7,  desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.9,  desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.1,  desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.17, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.22, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.12, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.12, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.06, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.27, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.44, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 1.9,\n  },\n  // ── PLAN 2: スタンダードプラン（バランス）──\n  {\n    name: 'スタンダードプラン',\n    nameEn: 'STANDARD',\n    period: [\n      { label: '1ヶ月', coeff: 1.2, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.5, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 2.0, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 3.0, desc: '年間継続展開' },\n      { label: '2年',   coeff: 4.5, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 6.0, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.5, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.2, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.5, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.8, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.0, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.2, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.18, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.25, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.07, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.3,  desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.45, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 2.0,\n  },\n  // ── PLAN 3: プレミアムプラン（アップセル）──\n  {\n    name: 'プレミアムプラン',\n    nameEn: 'PREMIUM',\n    period: [\n      { label: '1ヶ月', coeff: 1.5, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.8, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 2.4, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 3.6, desc: '年間継続展開' },\n      { label: '2年',   coeff: 5.4, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 7.2, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 2.0, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.5, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 3.0, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 3.0,\n  },\n];\n\n// GOKKO Margin is shared across all plans (3 tiers)\nconst MARGIN = [\n  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n];\n\n// Talent rank is shared across all plans\nconst RANK = [\n  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n];\n\n// ═══════════════════════════════════════\n// STATE\n// ═══════════════════════════════════════\nlet currentPlan = 2; // default: スタンダード\nconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\nlet simulatorInitialized = false;\nconst REQUIRED_SIMULATOR_IDS = ['baseFee', 'coeffGrid', 'resultPlanBadge', 'resultBreakdown', 'resultValue', 'resultLiveRegion'];\n\n// ═══════════════════════════════════════\n// YEAR SYNC\n// ═══════════════════════════════════════\nfunction syncCurrentYear() {\n  const y = String(new Date().getFullYear());\n  document.querySelectorAll('.copyright-year').forEach(el => { el.textContent = y; });\n  document.querySelectorAll('.menu-year').forEach(el => { el.textContent = y; });\n}\n\nfunction hasRequiredSimulatorMarkup() {\n  return REQUIRED_SIMULATOR_IDS.every(id => document.getElementById(id));\n}\n\nfunction resetSelections() {\n  state.period = 0;\n  state.competition = 0;\n  state.industry = 0;\n  state.media = [0];\n  state.rank = 0;\n  state.margin = 0;\n}\n\n// ═══════════════════════════════════════\n// PLAN SELECTOR\n// ═══════════════════════════════════════\nfunction selectPlan(btn) {\n  currentPlan = parseInt(btn.dataset.plan, 10);\n  document.querySelectorAll('.plan-btn').forEach(b => {\n    b.classList.remove('active');\n    b.setAttribute('aria-checked', 'false');\n  });\n  btn.classList.add('active');\n  btn.setAttribute('aria-checked', 'true');\n  resetSelections();\n  renderCards();\n  calculate();\n}\n\n// ═══════════════════════════════════════\n// RENDER\n// ═══════════════════════════════════════\nfunction getCoeffCategories() {\n  const plan = PLANS[currentPlan];\n  return [\n    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n  ];\n}\n\nfunction renderCards() {\n  const grid = document.getElementById('coeffGrid');\n  if (!grid) return;\n  grid.innerHTML = '';\n  const cats = getCoeffCategories();\n\n  cats.forEach(cat => {\n    const card = document.createElement('div');\n    card.className = 'coeff-card';\n    const isCheck = cat.type === 'checkbox';\n\n    let html = '';\n    cat.options.forEach((opt, i) => {\n      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `\\u00d7${opt.coeff}`;\n      const role = isCheck ? 'checkbox' : 'radio';\n      const ariaChecked = sel ? 'true' : 'false';\n      const ariaDisabled = opt.base ? 'true' : 'false';\n      const tabIndex = opt.base ? '-1' : '0';\n      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n        <div class=\"opt-coeff\">${cv}</div></div>`;\n    });\n\n    const capNote = cat.cap ? `<div class=\"media-note\">\\u203b \\u52a0\\u7b97\\u5408\\u8a08\\u306e\\u4e0a\\u9650\\uff08Cap\\uff09: \\u00d7${cat.cap}</div>` : '';\n    const groupRole = isCheck ? 'group' : 'radiogroup';\n\n    card.innerHTML = `<div class=\"coeff-header\">\n      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n\n    grid.appendChild(card);\n  });\n\n  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n    el.addEventListener('click', handleClick);\n    el.addEventListener('keydown', (e) => {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        handleClick(e);\n      }\n    });\n  });\n}\n\nfunction handleClick(e) {\n  const el = e.currentTarget;\n  const catId = el.dataset.cat;\n  const idx = parseInt(el.dataset.idx, 10);\n  const cats = getCoeffCategories();\n  const cat = cats.find(c => c.id === catId);\n  if (!cat) return;\n\n  if (cat.type === 'checkbox') {\n    if (el.dataset.base) return;\n    const a = state[catId];\n    const p = a.indexOf(idx);\n    p > -1 ? a.splice(p, 1) : a.push(idx);\n  } else {\n    state[catId] = idx;\n  }\n  renderCards();\n  calculate();\n}\n\n// ═══════════════════════════════════════\n// CALCULATE\n// ═══════════════════════════════════════\nfunction calculate() {\n  const baseFeeInput = document.getElementById('baseFee');\n  const resultPlanBadge = document.getElementById('resultPlanBadge');\n  const resultBreakdown = document.getElementById('resultBreakdown');\n  const resultValue = document.getElementById('resultValue');\n  const resultLiveRegion = document.getElementById('resultLiveRegion');\n  if (!baseFeeInput || !resultPlanBadge || !resultBreakdown || !resultValue || !resultLiveRegion) return;\n\n  const plan = PLANS[currentPlan];\n  const baseFee = parseInt(baseFeeInput.value.replace(/[^0-9]/g, ''), 10) || 0;\n\n  const pCoeff = plan.period[state.period].coeff;\n  const cCoeff = plan.competition[state.competition].coeff;\n  const iCoeff = plan.industry[state.industry].coeff;\n\n  let mSum = 0;\n  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n  const mCoeff = Math.min(mSum, plan.mediaCap);\n\n  const rCoeff = RANK[state.rank].coeff;\n  const marginCoeff = MARGIN[state.margin].coeff;\n\n  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n\n  resultPlanBadge.textContent = plan.nameEn;\n\n  const chips = [\n    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n  ];\n  resultBreakdown.innerHTML = chips.map((c, i) =>\n    `<span class=\"result-chip\">${c.l} <span>\\u00d7${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">\\u00d7</span>' : ''}`\n  ).join('');\n\n  const formattedTotal = '\\u00a5' + Math.round(total).toLocaleString('ja-JP');\n  resultValue.textContent = formattedTotal;\n  resultLiveRegion.textContent =\n    `${plan.name}\\u3001\\u898b\\u7a4d\\u7dcf\\u984d ${formattedTotal}\\u3002\\u671f\\u9593 ${pCoeff}\\u3001\\u7af6\\u5408 ${cCoeff}\\u3001\\u696d\\u754c ${iCoeff}\\u3001\\u30e1\\u30c7\\u30a3\\u30a2 ${mCoeff}\\u3001\\u30e9\\u30f3\\u30af ${rCoeff}\\u3001\\u30de\\u30fc\\u30b8\\u30f3 ${marginCoeff}\\u3002`;\n}\n\n// ═══════════════════════════════════════\n// INIT\n// ═══════════════════════════════════════\nfunction initSimulator() {\n  if (simulatorInitialized) return true;\n  if (!hasRequiredSimulatorMarkup()) {\n    console.warn('Simulator markup is incomplete. Skipping initialization.');\n    return false;\n  }\n\n  // Plan selector events\n  document.querySelectorAll('.plan-btn').forEach(btn => {\n    btn.addEventListener('click', () => selectPlan(btn));\n    btn.addEventListener('keydown', (e) => {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        selectPlan(btn);\n      }\n    });\n  });\n\n  // Base fee input formatting\n  document.getElementById('baseFee').addEventListener('input', function() {\n    const raw = this.value.replace(/[^0-9]/g, '');\n    this.value = raw ? parseInt(raw, 10).toLocaleString('ja-JP') : '';\n    calculate();\n  });\n\n  // Dynamic year\n  syncCurrentYear();\n\n  // Initial render\n  simulatorInitialized = true;\n  renderCards();\n  calculate();\n  console.log('\\u2705 \\u521d\\u671f\\u5316\\u5b8c\\u4e86: \\u30ab\\u30fc\\u30c9\\u6570 =', document.querySelectorAll('.coeff-card').length);\n  return true;\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
