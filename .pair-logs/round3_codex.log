{"type":"item.completed","item":{"id":"item_3","type":"command_execution","command":"/bin/zsh -lc \"nl -ba shared.js | sed -n '260,460p'\"","aggregated_output":"   260\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n   261\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `\\u00d7${opt.coeff}`;\n   262\t      const role = isCheck ? 'checkbox' : 'radio';\n   263\t      const ariaChecked = sel ? 'true' : 'false';\n   264\t      const ariaDisabled = opt.base ? 'true' : 'false';\n   265\t      const tabIndex = opt.base ? '-1' : '0';\n   266\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n   267\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n   268\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n   269\t    });\n   270\t\n   271\t    const capNote = cat.cap ? `<div class=\"media-note\">\\u203b \\u52a0\\u7b97\\u5408\\u8a08\\u306e\\u4e0a\\u9650\\uff08Cap\\uff09: \\u00d7${cat.cap}</div>` : '';\n   272\t    const groupRole = isCheck ? 'group' : 'radiogroup';\n   273\t\n   274\t    card.innerHTML = `<div class=\"coeff-header\">\n   275\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n   276\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n   277\t\n   278\t    grid.appendChild(card);\n   279\t  });\n   280\t\n   281\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n   282\t    el.addEventListener('click', handleClick);\n   283\t    el.addEventListener('keydown', (e) => {\n   284\t      if (e.key === 'Enter' || e.key === ' ') {\n   285\t        e.preventDefault();\n   286\t        handleClick(e);\n   287\t      }\n   288\t    });\n   289\t  });\n   290\t}\n   291\t\n   292\tfunction handleClick(e) {\n   293\t  const el = e.currentTarget;\n   294\t  const catId = el.dataset.cat;\n   295\t  const idx = parseInt(el.dataset.idx, 10);\n   296\t  const cats = getCoeffCategories();\n   297\t  const cat = cats.find(c => c.id === catId);\n   298\t  if (!cat) return;\n   299\t\n   300\t  if (cat.type === 'checkbox') {\n   301\t    if (el.dataset.base) return;\n   302\t    const a = state[catId];\n   303\t    const p = a.indexOf(idx);\n   304\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n   305\t  } else {\n   306\t    state[catId] = idx;\n   307\t  }\n   308\t  renderCards();\n   309\t  calculate();\n   310\t}\n   311\t\n   312\t// ═══════════════════════════════════════\n   313\t// CALCULATE\n   314\t// ═══════════════════════════════════════\n   315\tfunction calculate() {\n   316\t  const baseFeeInput = document.getElementById('baseFee');\n   317\t  const resultPlanBadge = document.getElementById('resultPlanBadge');\n   318\t  const resultBreakdown = document.getElementById('resultBreakdown');\n   319\t  const resultValue = document.getElementById('resultValue');\n   320\t  const resultLiveRegion = document.getElementById('resultLiveRegion');\n   321\t  if (!baseFeeInput || !resultPlanBadge || !resultBreakdown || !resultValue || !resultLiveRegion) return;\n   322\t\n   323\t  const plan = PLANS[currentPlan];\n   324\t  const baseFee = parseInt(baseFeeInput.value.replace(/[^0-9]/g, ''), 10) || 0;\n   325\t\n   326\t  const pCoeff = (plan.period[state.period] || plan.period[0]).coeff;\n   327\t  const cCoeff = (plan.competition[state.competition] || plan.competition[0]).coeff;\n   328\t  const iCoeff = (plan.industry[state.industry] || plan.industry[0]).coeff;\n   329\t\n   330\t  let mSum = 0;\n   331\t  state.media.forEach(i => { if (plan.media[i]) mSum += plan.media[i].coeff; });\n   332\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n   333\t\n   334\t  const rCoeff = (RANK[state.rank] || RANK[0]).coeff;\n   335\t  const marginCoeff = (MARGIN[state.margin] || MARGIN[0]).coeff;\n   336\t\n   337\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n   338\t\n   339\t  resultPlanBadge.textContent = plan.nameEn;\n   340\t\n   341\t  const chips = [\n   342\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n   343\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n   344\t  ];\n   345\t  resultBreakdown.innerHTML = chips.map((c, i) =>\n   346\t    `<span class=\"result-chip\">${c.l} <span>\\u00d7${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">\\u00d7</span>' : ''}`\n   347\t  ).join('');\n   348\t\n   349\t  const formattedTotal = '\\u00a5' + Math.round(total).toLocaleString('ja-JP');\n   350\t  resultValue.textContent = formattedTotal;\n   351\t  resultLiveRegion.textContent =\n   352\t    `${plan.name}\\u3001\\u898b\\u7a4d\\u7dcf\\u984d ${formattedTotal}\\u3002\\u671f\\u9593 ${pCoeff}\\u3001\\u7af6\\u5408 ${cCoeff}\\u3001\\u696d\\u754c ${iCoeff}\\u3001\\u30e1\\u30c7\\u30a3\\u30a2 ${mCoeff}\\u3001\\u30e9\\u30f3\\u30af ${rCoeff}\\u3001\\u30de\\u30fc\\u30b8\\u30f3 ${marginCoeff}\\u3002`;\n   353\t}\n   354\t\n   355\t// ═══════════════════════════════════════\n   356\t// INIT\n   357\t// ═══════════════════════════════════════\n   358\tfunction initSimulator() {\n   359\t  if (simulatorInitialized) return true;\n   360\t  if (!hasRequiredSimulatorMarkup()) {\n   361\t    console.warn('Simulator markup is incomplete. Skipping initialization.');\n   362\t    return false;\n   363\t  }\n   364\t\n   365\t  // Plan selector — roving tabindex + arrow key navigation (WAI-ARIA radiogroup)\n   366\t  const planBtns = Array.from(document.querySelectorAll('.plan-btn'));\n   367\t  planBtns.forEach((btn, idx) => {\n   368\t    btn.setAttribute('tabindex', btn.classList.contains('active') ? '0' : '-1');\n   369\t    btn.addEventListener('click', () => selectPlan(btn));\n   370\t    btn.addEventListener('keydown', (e) => {\n   371\t      if (e.key === 'Enter' || e.key === ' ') {\n   372\t        e.preventDefault();\n   373\t        selectPlan(btn);\n   374\t        return;\n   375\t      }\n   376\t      let target;\n   377\t      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n   378\t        target = planBtns[(idx + 1) % planBtns.length];\n   379\t      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n   380\t        target = planBtns[(idx - 1 + planBtns.length) % planBtns.length];\n   381\t      } else if (e.key === 'Home') {\n   382\t        target = planBtns[0];\n   383\t      } else if (e.key === 'End') {\n   384\t        target = planBtns[planBtns.length - 1];\n   385\t      }\n   386\t      if (target) {\n   387\t        e.preventDefault();\n   388\t        selectPlan(target);\n   389\t      }\n   390\t    });\n   391\t  });\n   392\t\n   393\t  // Base fee input formatting\n   394\t  document.getElementById('baseFee').addEventListener('input', function() {\n   395\t    const raw = this.value.replace(/[^0-9]/g, '');\n   396\t    this.value = raw ? parseInt(raw, 10).toLocaleString('ja-JP') : '';\n   397\t    calculate();\n   398\t  });\n   399\t\n   400\t  // Dynamic year\n   401\t  syncCurrentYear();\n   402\t\n   403\t  // Initial render\n   404\t  simulatorInitialized = true;\n   405\t  renderCards();\n   406\t  calculate();\n   407\t  console.log('\\u2705 \\u521d\\u671f\\u5316\\u5b8c\\u4e86: \\u30ab\\u30fc\\u30c9\\u6570 =', document.querySelectorAll('.coeff-card').length);\n   408\t  return true;\n   409\t}\n   410\t\n   411\t// Expose public API\n   412\twindow.initSimulator = initSimulator;\n   413\t\n   414\t})(window);\n","exit_code":0,"status":"completed"}}
