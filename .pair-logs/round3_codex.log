> = 基本出演料 × 使用期間 × 競合排除 × 業界 × メディア × 出演者ランク × マージン\n   156\t</div>\n   157\t\n   158\t<!-- ── Main ── -->\n   159\t<div class=\"container\">\n   160\t\n   161\t  <!-- Base Fee -->\n   162\t  <section class=\"section\">\n   163\t    <div class=\"section-label\">Base Fee</div>\n   164\t    <div class=\"section-title\">基本出演料を入力</div>\n   165\t    <div class=\"base-fee-card\">\n   166\t      <label>ショートドラマ出演時のキャスティング費（税別）</label>\n   167\t      <div class=\"input-row\">\n   168\t        <span>¥</span>\n   169\t        <input type=\"text\" class=\"base-fee-input\" id=\"baseFee\" placeholder=\"100,000\" value=\"100,000\" inputmode=\"numeric\" aria-label=\"基本出演料\">\n   170\t      </div>\n   171\t    </div>\n   172\t  </section>\n   173\t\n   174\t  <!-- Coefficients -->\n   175\t  <section class=\"section\">\n   176\t    <div class=\"section-label\">Coefficients</div>\n   177\t    <div class=\"section-title\">各係数を選択してください</div>\n   178\t    <div class=\"coeff-grid\" id=\"coeffGrid\"></div>\n   179\t  </section>\n   180\t\n   181\t  <!-- Reference -->\n   182\t  <section class=\"section\">\n   183\t    <div class=\"section-label\">Reference</div>\n   184\t    <div class=\"section-title\">出演者ランク別 基本出演料の目安</div>\n   185\t    <div class=\"ref-table-wrap\">\n   186\t      <table class=\"ref-table\">\n   187\t        <thead>\n   188\t          <tr><th>ランク</th><th>係数</th><th>説明</th><th>基本出演料目安</th></tr>\n   189\t        </thead>\n   190\t        <tbody>\n   191\t          <tr><td>新人A</td><td>×0.8</td><td>GOKKO専属新人</td><td>5万円</td></tr>\n   192\t          <tr><td>新人B</td><td>×1.0</td><td>一般新人キャスト</td><td>8〜12万円</td></tr>\n   193\t          <tr><td>準中堅</td><td>×1.8</td><td>実績ある若手</td><td>15〜25万円</td></tr>\n   194\t          <tr><td>中堅A</td><td>×2.5</td><td>中堅タレント</td><td>30〜40万円</td></tr>\n   195\t          <tr><td>中堅B</td><td>×3.5</td><td>人気中堅タレント</td><td>50〜80万円</td></tr>\n   196\t          <tr><td>準有名</td><td>×5.0</td><td>知名度上昇中</td><td>80〜120万円</td></tr>\n   197\t          <tr><td>有名A</td><td>×8.0</td><td>有名タレント</td><td>150〜300万円</td></tr>\n   198\t          <tr><td>有名S</td><td>×12.0</td><td>トップクラス</td><td>500万円以上</td></tr>\n   199\t        </tbody>\n   200\t      </table>\n   201\t    </div>\n   202\t  </section>\n   203\t</div>\n   204\t\n   205\t<!-- ── Sticky Result ── -->\n   206\t<div class=\"result-panel\" id=\"resultPanel\">\n   207\t  <div class=\"result-inner\">\n   208\t    <div class=\"result-left\">\n   209\t      <div class=\"result-plan-badge\" id=\"resultPlanBadge\">STANDARD</div>\n   210\t      <div class=\"result-breakdown\" id=\"resultBreakdown\"></div>\n   211\t    </div>\n   212\t    <div class=\"result-total\">\n   213\t      <div class=\"result-total-label\">Estimated Total</div>\n   214\t      <div class=\"result-total-value\" id=\"resultValue\" aria-live=\"polite\" aria-atomic=\"true\">¥0</div>\n   215\t    </div>\n   216\t  </div>\n   217\t  <div class=\"sr-only\" id=\"resultLiveRegion\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n   218\t</div>\n   219\t\n   220\t<!-- ── Footer ── -->\n   221\t<footer class=\"footer\">\n   222\t  © <span class=\"copyright-year\"></span> GOKKO Inc. All rights reserved. ｜ 本料金表は参考価格です。正式なお見積りは別途ご相談ください。\n   223\t</footer>\n   224\t\n   225\t</div><!-- /app-content -->\n   226\t\n   227\t<script>\n   228\t// ═══════════════════════════════════════\n   229\t// GOOGLE AUTH\n   230\t// ═══════════════════════════════════════\n   231\tconst GOOGLE_CLIENT_ID = '777058430626-nla9pd956ss4t7jrchf58ebc0u614rcq.apps.googleusercontent.com';\n   232\tconst ALLOWED_DOMAIN = 'gokkoclub.jp';\n   233\t\n   234\tfunction showApp() {\n   235\t  hideLoginError();\n   236\t  setLoginBusy(false);\n   237\t  document.getElementById('loginOverlay').classList.add('hidden');\n   238\t  document.getElementById('appContent').classList.add('visible');\n   239\t}\n   240\t\n   241\tfunction showLoggedOutState() {\n   242\t  setLoginBusy(false);\n   243\t  document.getElementById('loginOverlay').classList.remove('hidden');\n   244\t  document.getElementById('appContent').classList.remove('visible');\n   245\t}\n   246\t\n   247\tfunction showLoginError(message) {\n   248\t  const errorEl = document.getElementById('loginError');\n   249\t  errorEl.textContent = message;\n   250\t  errorEl.style.display = 'block';\n   251\t}\n   252\t\n   253\tfunction hideLoginError() {\n   254\t  document.getElementById('loginError').style.display = 'none';\n   255\t}\n   256\t\n   257\tfunction setLoginBusy(isBusy) {\n   258\t  const loginButton = document.getElementById('googleLoginBtn');\n   259\t  if (!loginButton) return;\n   260\t  loginButton.disabled = isBusy;\n   261\t  loginButton.setAttribute('aria-busy', String(isBusy));\n   262\t}\n   263\t\n   264\tfunction getGoogleLoginErrorMessage(errorCode) {\n   265\t  if (errorCode === 'access_denied') {\n   266\t    return 'Google ログインがキャンセルされました。再度お試しください。';\n   267\t  }\n   268\t  if (errorCode === 'popup_closed' || errorCode === 'popup_closed_by_user') {\n   269\t    return 'Google ログインの画面が閉じられました。再度お試しください。';\n   270\t  }\n   271\t  return 'Googleログインに失敗しました。再度お試しください。';\n   272\t}\n   273\t\n   274\tfunction getVerificationErrorMessage(error) {\n   275\t  if (String(error?.message || '').includes('401')) {\n   276\t    return 'ログインの有効期限が切れました。再度ログインしてください。';\n   277\t  }\n   278\t  return 'ログイン状態を確認できませんでした。再度ログインしてください。';\n   279\t}\n   280\t\n   281\tfunction handleGoogleLogin() {\n   282\t  hideLoginError();\n   283\t  if (!window.google?.accounts?.oauth2?.initTokenClient) {\n   284\t    showLoginError('Googleログインの準備がまだ完了していません。少し待って再度お試しください。');\n   285\t    return;\n   286\t  }\n   287\t  setLoginBusy(true);\n   288\t  try {\n   289\t    const client = google.accounts.oauth2.initTokenClient({\n   290\t      client_id: GOOGLE_CLIENT_ID,\n   291\t      scope: 'email profile',\n   292\t      callback: (response) => {\n   293\t        if (response.error) {\n   294\t          setLoginBusy(false);\n   295\t          showLoginError(getGoogleLoginErrorMessage(response.error));\n   296\t          return;\n   297\t        }\n   298\t        if (response.access_token) {\n   299\t          verifyAndShowApp(response.access_token);\n   300\t        } else {\n   301\t          setLoginBusy(false);\n   302\t        }\n   303\t      },\n   304\t      error_callback: (err) => {\n   305\t        setLoginBusy(false);\n   306\t        if (err.type === 'popup_failed_to_open') {\n   307\t          showLoginError('ポップアップがブロックされました。ブラウザの設定を確認してください。');\n   308\t        } else if (err.type === 'popup_closed') {\n   309\t          showLoginError('ログイン画面が閉じられました。再度お試しください。');\n   310\t        } else {\n   311\t          showLoginError('Googleログインに失敗しました。再度お試しください。');\n   312\t        }\n   313\t      },\n   314\t    });\n   315\t    client.requestAccessToken();\n   316\t  } catch(e) {\n   317\t    setLoginBusy(false);\n   318\t    console.error('Google Auth error:', e);\n   319\t    showLoginError('Googleログインの読み込みに失敗しました。https:// でアクセスしてください。');\n   320\t  }\n   321\t}\n   322\t\n   323\tfunction verifyAndShowApp(accessToken) {\n   324\t  fetch('https://www.googleapis.com/oauth2/v3/userinfo', {\n   325\t    headers: { Authorization: 'Bearer ' + accessToken }\n   326\t  })\n   327\t  .then(r => {\n   328\t    if (!r.ok) throw new Error('userinfo request failed: ' + r.status);\n   329\t    return r.json();\n   330\t  })\n   331\t  .then(user => {\n   332\t    if (user.email && user.email.endsWith('@' + ALLOWED_DOMAIN)) {\n   333\t      sessionStorage.setItem('gokko_access_token', accessToken);\n   334\t      showApp();\n   335\t    } else {\n   336\t      sessionStorage.removeItem('gokko_access_token');\n   337\t      showLoggedOutState();\n   338\t      showLoginError('@gokkoclub.jp のメールアドレスでログインしてください');\n   339\t    }\n   340\t  })\n   341\t  .catch(err => {\n   342\t    console.error('Auth verification failed:', err);\n   343\t    sessionStorage.removeItem('gokko_access_token');\n   344\t    showLoggedOutState();\n   345\t    showLoginError(getVerificationErrorMessage(err));\n   346\t  });\n   347\t}\n   348\t\n   349\twindow.addEventListener('DOMContentLoaded', () => {\n   350\t  document.getElementById('googleLoginBtn').addEventListener('click', handleGoogleLogin);\n   351\t  const savedToken = sessionStorage.getItem('gokko_access_token');\n   352\t  if (savedToken) {\n   353\t    setLoginBusy(true);\n   354\t    verifyAndShowApp(savedToken);\n   355\t  } else {\n   356\t    showLoggedOutState();\n   357\t  }\n   358\t});\n   359\t</script>\n   360\t<script src=\"shared.js\"></script>\n   361\t<script>\n   362\ttry {\n   363\t  initSimulator();\n   364\t} catch(e) {\n   365\t  console.error('❌ 初期化エラー:', e);\n   366\t}\n   367\t</script>\n   368\t</body>\n   369\t</html>\n","exit_code":0,"status":"completed"}}
