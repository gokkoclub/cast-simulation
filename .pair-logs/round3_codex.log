ff: 3.0, desc: '特殊な規制対象業界' },\n   148\t    ],\n   149\t    media: [\n   150\t      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n   151\t      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n   152\t      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n   153\t      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n   154\t      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n   155\t      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n   156\t      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n   157\t      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n   158\t    ],\n   159\t    mediaCap: 3.0,\n   160\t  },\n   161\t];\n   162\t\n   163\t// GOKKO Margin is shared across all plans (3 tiers)\n   164\tconst MARGIN = [\n   165\t  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n   166\t  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n   167\t  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n   168\t];\n   169\t\n   170\t// Talent rank is shared across all plans\n   171\tconst RANK = [\n   172\t  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n   173\t  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n   174\t  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n   175\t  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n   176\t  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n   177\t  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n   178\t  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n   179\t  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n   180\t];\n   181\t\n   182\t// ═══════════════════════════════════════\n   183\t// STATE\n   184\t// ═══════════════════════════════════════\n   185\tlet currentPlan = 2; // default: スタンダード\n   186\tconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n   187\tlet simulatorInitialized = false;\n   188\tconst REQUIRED_SIMULATOR_IDS = ['baseFee', 'coeffGrid', 'resultPlanBadge', 'resultBreakdown', 'resultValue', 'resultLiveRegion'];\n   189\t\n   190\t// ═══════════════════════════════════════\n   191\t// YEAR SYNC\n   192\t// ═══════════════════════════════════════\n   193\tfunction syncCurrentYear() {\n   194\t  const y = String(new Date().getFullYear());\n   195\t  document.querySelectorAll('.copyright-year').forEach(el => { el.textContent = y; });\n   196\t  document.querySelectorAll('.menu-year').forEach(el => { el.textContent = y; });\n   197\t}\n   198\t\n   199\tfunction hasRequiredSimulatorMarkup() {\n   200\t  return REQUIRED_SIMULATOR_IDS.every(id => document.getElementById(id));\n   201\t}\n   202\t\n   203\tfunction resetSelections() {\n   204\t  state.period = 0;\n   205\t  state.competition = 0;\n   206\t  state.industry = 0;\n   207\t  state.media = [0];\n   208\t  state.rank = 0;\n   209\t  state.margin = 0;\n   210\t}\n   211\t\n   212\t// ═══════════════════════════════════════\n   213\t// PLAN SELECTOR\n   214\t// ═══════════════════════════════════════\n   215\tfunction selectPlan(btn) {\n   216\t  currentPlan = parseInt(btn.dataset.plan, 10);\n   217\t  document.querySelectorAll('.plan-btn').forEach(b => {\n   218\t    b.classList.remove('active');\n   219\t    b.setAttribute('aria-checked', 'false');\n   220\t    b.setAttribute('tabindex', '-1');\n   221\t  });\n   222\t  btn.classList.add('active');\n   223\t  btn.setAttribute('aria-checked', 'true');\n   224\t  btn.setAttribute('tabindex', '0');\n   225\t  btn.focus();\n   226\t  resetSelections();\n   227\t  renderCards();\n   228\t  calculate();\n   229\t}\n   230\t\n   231\t// ═══════════════════════════════════════\n   232\t// RENDER\n   233\t// ═══════════════════════════════════════\n   234\tfunction getCoeffCategories() {\n   235\t  const plan = PLANS[currentPlan];\n   236\t  return [\n   237\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n   238\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n   239\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n   240\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n   241\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n   242\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n   243\t  ];\n   244\t}\n   245\t\n   246\tfunction renderCards() {\n   247\t  const grid = document.getElementById('coeffGrid');\n   248\t  if (!grid) return;\n   249\t  grid.innerHTML = '';\n   250\t  const cats = getCoeffCategories();\n   251\t\n   252\t  cats.forEach(cat => {\n   253\t    const card = document.createElement('div');\n   254\t    card.className = 'coeff-card';\n   255\t    const isCheck = cat.type === 'checkbox';\n   256\t\n   257\t    let html = '';\n   258\t    cat.options.forEach((opt, i) => {\n   259\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n   260\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n","exit_code":0,"status":"completed"}}
