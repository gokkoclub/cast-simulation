y: 0.09s; }\n  .coeff-card:nth-child(4) { animation-delay: 0.12s; }\n  .coeff-card:nth-child(5) { animation-delay: 0.15s; }\n  .coeff-card:nth-child(6) { animation-delay: 0.18s; }\n\n  .sr-only {\n    position: absolute;\n    width: 1px;\n    height: 1px;\n    padding: 0;\n    margin: -1px;\n    overflow: hidden;\n    clip: rect(0, 0, 0, 0);\n    white-space: nowrap;\n    border: 0;\n  }\n\n  .app-content { display: block; }\n</style>\n</head>\n<body>\n\n<!-- ── App Content ── -->\n<div class=\"app-content\" id=\"appContent\">\n\n<!-- ── Hero ── -->\n<section class=\"hero\">\n  <div class=\"hero-badge\">GOKKO Inc. — Advertising Menu 2025</div>\n  <h1>Ad Pricing<br>Simulator</h1>\n  <p>縦型ショートドラマ広告利用の料金を、プランと各係数からリアルタイムでシミュレーション</p>\n\n  <div class=\"plan-selector\" id=\"planSelector\" role=\"radiogroup\" aria-label=\"プラン選択\">\n    <div class=\"plan-btn\" data-plan=\"0\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n      <span class=\"plan-num\">PLAN 01</span>\n      <span class=\"plan-name\">ライトプラン</span>\n      <span class=\"plan-sub\">フック重視</span>\n    </div>\n    <div class=\"plan-btn\" data-plan=\"1\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n      <span class=\"plan-num\">PLAN 02</span>\n      <span class=\"plan-name\">ベーシックプラン</span>\n      <span class=\"plan-sub\">実稼働費回収</span>\n    </div>\n    <div class=\"plan-btn active\" data-plan=\"2\" role=\"radio\" aria-checked=\"true\" tabindex=\"0\">\n      <span class=\"plan-recommended\">RECOMMENDED</span>\n      <span class=\"plan-num\">PLAN 03</span>\n      <span class=\"plan-name\">スタンダードプラン</span>\n      <span class=\"plan-sub\">バランス型</span>\n    </div>\n    <div class=\"plan-btn\" data-plan=\"3\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n      <span class=\"plan-num\">PLAN 04</span>\n      <span class=\"plan-name\">プレミアムプラン</span>\n      <span class=\"plan-sub\">アップセル</span>\n    </div>\n  </div>\n</section>\n\n<!-- ── Formula Bar ── -->\n<div class=\"formula-bar\">\n  <span>総額</span> = 基本出演料 × 使用期間 × 競合排除 × 業界 × メディア × 出演者ランク × マージン\n</div>\n\n<!-- ── Main ── -->\n<div class=\"container\">\n\n  <!-- Base Fee -->\n  <section class=\"section\">\n    <div class=\"section-label\">Base Fee</div>\n    <div class=\"section-title\">基本出演料を入力</div>\n    <div class=\"base-fee-card\">\n      <label>ショートドラマ出演時のキャスティング費（税別）</label>\n      <div class=\"input-row\">\n        <span>¥</span>\n        <input type=\"text\" class=\"base-fee-input\" id=\"baseFee\" placeholder=\"100,000\" value=\"100,000\" inputmode=\"numeric\" aria-label=\"基本出演料\">\n      </div>\n    </div>\n  </section>\n\n  <!-- Coefficients -->\n  <section class=\"section\">\n    <div class=\"section-label\">Coefficients</div>\n    <div class=\"section-title\">各係数を選択してください</div>\n    <div class=\"coeff-grid\" id=\"coeffGrid\"></div>\n  </section>\n\n  <!-- Reference -->\n  <section class=\"section\">\n    <div class=\"section-label\">Reference</div>\n    <div class=\"section-title\">出演者ランク別 基本出演料の目安</div>\n    <div class=\"ref-table-wrap\">\n      <table class=\"ref-table\">\n        <thead>\n          <tr><th>ランク</th><th>係数</th><th>説明</th><th>基本出演料目安</th></tr>\n        </thead>\n        <tbody>\n          <tr><td>新人A</td><td>×0.8</td><td>GOKKO専属新人</td><td>5万円</td></tr>\n          <tr><td>新人B</td><td>×1.0</td><td>一般新人キャスト</td><td>8〜12万円</td></tr>\n          <tr><td>準中堅</td><td>×1.8</td><td>実績ある若手</td><td>15〜25万円</td></tr>\n          <tr><td>中堅A</td><td>×2.5</td><td>中堅タレント</td><td>30〜40万円</td></tr>\n          <tr><td>中堅B</td><td>×3.5</td><td>人気中堅タレント</td><td>50〜80万円</td></tr>\n          <tr><td>準有名</td><td>×5.0</td><td>知名度上昇中</td><td>80〜120万円</td></tr>\n          <tr><td>有名A</td><td>×8.0</td><td>有名タレント</td><td>150〜300万円</td></tr>\n          <tr><td>有名S</td><td>×12.0</td><td>トップクラス</td><td>500万円以上</td></tr>\n        </tbody>\n      </table>\n    </div>\n  </section>\n</div>\n\n<!-- ── Sticky Result ── -->\n<div class=\"result-panel\" id=\"resultPanel\">\n  <div class=\"result-inner\">\n    <div class=\"result-left\">\n      <div class=\"result-plan-badge\" id=\"resultPlanBadge\">STANDARD</div>\n      <div class=\"result-breakdown\" id=\"resultBreakdown\"></div>\n    </div>\n    <div class=\"result-total\">\n      <div class=\"result-total-label\">Estimated Total</div>\n      <div class=\"result-total-value\" id=\"resultValue\" aria-live=\"polite\" aria-atomic=\"true\">¥0</div>\n    </div>\n  </div>\n  <div class=\"sr-only\" id=\"resultLiveRegion\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n</div>\n\n<!-- ── Footer ── -->\n<footer class=\"footer\">\n  © <span class=\"copyright-year\">2026</span> GOKKO Inc. All rights reserved. ｜ 本料金表は参考価格です。正式なお見積りは別途ご相談ください。\n</footer>\n\n</div><!-- /app-content -->\n\n<script>\n// ═══════════════════════════════════════\n// PLAN DATA — 4 plans × 5 coefficient categories\n// ═══════════════════════════════════════\nconst PLANS = [\n  // ── PLAN 0: ライトプラン（フック重視）──\n  {\n    name: 'ライトプラン',\n    nameEn: 'LIGHT',\n    period: [\n      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.1, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.3, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.6, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.8, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.2,  desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.1,  desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.1,  desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.05, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.25, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.4,  desc: 'TikTokに加算' },\n    ],\n    mediaCap: 1.8,\n  },\n  // ── PLAN 1: ベーシックプラン（実稼働費回収）──\n  {\n    name: 'ベーシックプラン',\n    nameEn: 'BASIC',\n    period: [\n      { label: '1ヶ月', coeff: 1.0, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.2, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 1.6, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 2.4, desc: '年間継続展開' },\n      { label: '2年',   coeff: 3.6, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 4.8, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.4, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0,  desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.15, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.4,  desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.7,  desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.9,  desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.1,  desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.17, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.22, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.12, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.12, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.06, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.27, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.44, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 1.9,\n  },\n  // ── PLAN 2: スタンダードプラン（バランス）──\n  {\n    name: 'スタンダードプラン',\n    nameEn: 'STANDARD',\n    period: [\n      { label: '1ヶ月', coeff: 1.2, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.5, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 2.0, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 3.0, desc: '年間継続展開' },\n      { label: '2年',   coeff: 4.5, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 6.0, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.5, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.2, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.5, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 1.8, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.0, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.2, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.18, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.25, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.15, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.07, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.3,  desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.45, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 2.0,\n  },\n  // ── PLAN 3: プレミアムプラン（アップセル）──\n  {\n    name: 'プレミアムプラン',\n    nameEn: 'PREMIUM',\n    period: [\n      { label: '1ヶ月', coeff: 1.5, desc: 'お試し配信' },\n      { label: '3ヶ月', coeff: 1.8, desc: '短期集中キャンペーン' },\n      { label: '6ヶ月', coeff: 2.4, desc: '標準的な広告契約' },\n      { label: '1年',   coeff: 3.6, desc: '年間継続展開' },\n      { label: '2年',   coeff: 5.4, desc: '長期ブランド戦略' },\n      { label: '無期限', coeff: 7.2, desc: '恒久的な利用権' },\n    ],\n    competition: [\n      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n      { label: '商品競合のみ', coeff: 2.0, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.5, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 3.0, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 3.0,\n  },\n];\n\n// GOKKO Margin is shared across all plans (3 tiers)\nconst MARGIN = [\n  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n];\n\n// Talent rank is shared across all plans\nconst RANK = [\n  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n];\n\n// ═══════════════════════════════════════\n// STATE\n// ═══════════════════════════════════════\nlet currentPlan = 2; // default: スタンダード\nconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n\n// ═══════════════════════════════════════\n// PLAN SELECTOR\n// ═══════════════════════════════════════\nfunction syncCurrentYear() {\n  const currentYear = new Date().getFullYear();\n  document.querySelectorAll('.copyright-year').forEach(el => {\n    el.textContent = String(currentYear);\n  });\n}\n\nfunction selectPlan(btn) {\n  currentPlan = parseInt(btn.dataset.plan);\n  document.querySelectorAll('.plan-btn').forEach(b => {\n    b.classList.remove('active');\n    b.setAttribute('aria-checked', 'false');\n  });\n  btn.classList.add('active');\n  btn.setAttribute('aria-checked', 'true');\n  // Reset selections\n  state.period = 0; state.competition = 0; state.industry = 0; state.media = [0]; state.rank = 0; state.margin = 0;\n  renderCards();\n  calculate();\n}\n\ndocument.querySelectorAll('.plan-btn').forEach(btn => {\n  btn.addEventListener('click', () => selectPlan(btn));\n  btn.addEventListener('keydown', (e) => {\n    if (e.key === 'Enter' || e.key === ' ') {","numLines":400,"startLine":400,"totalLines":947}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0185pkKTFbsiCgXdQt6ftGqU","type":"tool_result","content":"800\t      e.preventDefault();\n801\t      selectPlan(btn);\n802\t    }\n803\t  });\n804\t});\n805\t\n806\t// ═══════════════════════════════════════\n807\t// RENDER\n808\t// ═══════════════════════════════════════\n809\tfunction getCoeffCategories() {\n810\t  const plan = PLANS[currentPlan];\n811\t  return [\n812\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n813\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n814\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n815\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n816\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n817\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n818\t  ];\n819\t}\n820\t\n821\tfunction renderCards() {\n822\t  const grid = document.getElementById('coeffGrid');\n823\t  grid.innerHTML = '';\n824\t  const cats = getCoeffCategories();\n825\t\n826\t  cats.forEach(cat => {\n827\t    const card = document.createElement('div');\n828\t    card.className = 'coeff-card';\n829\t    const isCheck = cat.type === 'checkbox';\n830\t\n831\t    let html = '';\n832\t    cat.options.forEach((opt, i) => {\n833\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n834\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n835\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n836\t      const role = isCheck ? 'checkbox' : 'radio';\n837\t      const ariaChecked = sel ? 'true' : 'false';\n838\t      const ariaDisabled = opt.base ? 'true' : 'false';\n839\t      const tabIndex = opt.base ? '-1' : '0';\n840\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n841\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n842\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n843\t    });\n844\t\n845\t    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n846\t    const groupRole = isCheck ? 'group' : 'radiogroup';\n847\t\n848\t    card.innerHTML = `<div class=\"coeff-header\">\n849\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n850\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n851\t\n852\t    grid.appendChild(card);\n853\t  });\n854\t\n855\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n856\t    el.addEventListener('click', handleClick);\n857\t    el.addEventListener('keydown', (e) => {\n858\t      if (e.key === 'Enter' || e.key === ' ') {\n859\t        e.preventDefault();\n860\t        handleClick(e);\n861\t      }\n862\t    });\n863\t  });\n864\t}\n865\t\n866\tfunction handleClick(e) {\n867\t  const el = e.currentTarget;\n868\t  const catId = el.dataset.cat;\n869\t  const idx = parseInt(el.dataset.idx);\n870\t  const cats = getCoeffCategories();\n871\t  const cat = cats.find(c => c.id === catId);\n872\t\n873\t  if (cat.type === 'checkbox') {\n874\t    if (el.dataset.base) return;\n875\t    const a = state[catId];\n876\t    const p = a.indexOf(idx);\n877\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n878\t  } else {\n879\t    state[catId] = idx;\n880\t  }\n881\t  renderCards();\n882\t  calculate();\n883\t}\n884\t\n885\t// ═══════════════════════════════════════\n886\t// CALCULATE\n887\t// ═══════════════════════════════════════\n888\tfunction calculate() {\n889\t  const plan = PLANS[currentPlan];\n890\t  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n891\t\n892\t  const pCoeff = plan.period[state.period].coeff;\n893\t  const cCoeff = plan.competition[state.competition].coeff;\n894\t  const iCoeff = plan.industry[state.industry].coeff;\n895\t\n896\t  let mSum = 0;\n897\t  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n898\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n899\t\n900\t  const rCoeff = RANK[state.rank].coeff;\n901\t  const marginCoeff = MARGIN[state.margin].coeff;\n902\t\n903\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n904\t\n905\t  // Badge\n906\t  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n907\t\n908\t  // Breakdown\n909\t  const bd = document.getElementById('resultBreakdown');\n910\t  const chips = [\n911\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n912\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n913\t  ];\n914\t  bd.innerHTML = chips.map((c, i) =>\n915\t    `<span class=\"result-chip\">${c.l} <span>×${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">×</span>' : ''}`\n916\t  ).join('');\n917\t\n918\t  const formattedTotal = '¥' + Math.round(total).toLocaleString('ja-JP');\n919\t  document.getElementById('resultValue').textContent = formattedTotal;\n920\t  document.getElementById('resultLiveRegion').textContent =\n921\t    `${plan.name}、見積総額 ${formattedTotal}。期間 ${pCoeff}、競合 ${cCoeff}、業界 ${iCoeff}、メディア ${mCoeff}、ランク ${rCoeff}、マージン ${marginCoeff}。`;\n922\t}\n923\t\n924\t// ═══════════════════════════════════════\n925\t// INPUT FORMAT\n926\t// ═══════════════════════════════════════\n927\tdocument.getElementById('baseFee').addEventListener('input', function() {\n928\t  let raw = this.value.replace(/[^0-9]/g, '');\n929\t  if (raw) this.value = parseInt(raw).toLocaleString('ja-JP');\n930\t  calculate();\n931\t});\n932\t\n933\t// ═══════════════════════════════════════\n934\t// INIT\n935\t// ═══════════════════════════════════════\n936\ttry {\n937\t  syncCurrentYear();\n938\t  renderCards();\n939\t  calculate();\n940\t  console.log('✅ 初期化完了: カード数 =', document.querySelectorAll('.coeff-card').length);\n941\t} catch(e) {\n942\t  console.error('❌ 初期化エラー:', e);\n943\t}\n944\t</script>\n945\t</body>\n946\t</html>\n947\t"}]},"parent_tool_use_id":null,"session_id":"99417205-2b4a-4073-8fe9-e262d832a3a7","uuid":"cd50554f-6f41-4ec0-bd2d-4a03aabf14e2","timestamp":"2026-04-09T09:34:11.440Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ucmuller/workspace/cast-simulation/gokko-ad-pricing-preview.html","content":"      e.preventDefault();\n      selectPlan(btn);\n    }\n  });\n});\n\n// ═══════════════════════════════════════\n// RENDER\n// ═══════════════════════════════════════\nfunction getCoeffCategories() {\n  const plan = PLANS[currentPlan];\n  return [\n    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n  ];\n}\n\nfunction renderCards() {\n  const grid = document.getElementById('coeffGrid');\n  grid.innerHTML = '';\n  const cats = getCoeffCategories();\n\n  cats.forEach(cat => {\n    const card = document.createElement('div');\n    card.className = 'coeff-card';\n    const isCheck = cat.type === 'checkbox';\n\n    let html = '';\n    cat.options.forEach((opt, i) => {\n      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n      const role = isCheck ? 'checkbox' : 'radio';\n      const ariaChecked = sel ? 'true' : 'false';\n      const ariaDisabled = opt.base ? 'true' : 'false';\n      const tabIndex = opt.base ? '-1' : '0';\n      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n        <div class=\"opt-coeff\">${cv}</div></div>`;\n    });\n\n    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n    const groupRole = isCheck ? 'group' : 'radiogroup';\n\n    card.innerHTML = `<div class=\"coeff-header\">\n      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n\n    grid.appendChild(card);\n  });\n\n  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n    el.addEventListener('click', handleClick);\n    el.addEventListener('keydown', (e) => {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        handleClick(e);\n      }\n    });\n  });\n}\n\nfunction handleClick(e) {\n  const el = e.currentTarget;\n  const catId = el.dataset.cat;\n  const idx = parseInt(el.dataset.idx);\n  const cats = getCoeffCategories();\n  const cat = cats.find(c => c.id === catId);\n\n  if (cat.type === 'checkbox') {\n    if (el.dataset.base) return;\n    const a = state[catId];\n    const p = a.indexOf(idx);\n    p > -1 ? a.splice(p, 1) : a.push(idx);\n  } else {\n    state[catId] = idx;\n  }\n  renderCards();\n  calculate();\n}\n\n// ═══════════════════════════════════════\n// CALCULATE\n// ═══════════════════════════════════════\nfunction calculate() {\n  const plan = PLANS[currentPlan];\n  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n\n  const pCoeff = plan.period[state.period].coeff;\n  const cCoeff = plan.competition[state.competition].coeff;\n  const iCoeff = plan.industry[state.industry].coeff;\n\n  let mSum = 0;\n  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n  const mCoeff = Math.min(mSum, plan.mediaCap);\n\n  const rCoeff = RANK[state.rank].coeff;\n  const marginCoeff = MARGIN[state.margin].coeff;\n\n  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n\n  // Badge\n  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n\n  // Breakdown\n  const bd = document.getElementById('resultBreakdown');\n  const chips = [\n    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n  ];\n  bd.innerHTML = chips.map((c, i) =>\n    `<span class=\"result-chip\">${c.l} <span>×${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">×</span>' : ''}`\n  ).join('');\n\n  const formattedTotal = '¥' + Math.round(total).toLocaleString('ja-JP');\n  document.getElementById('resultValue').textContent = formattedTotal;\n  document.getElementById('resultLiveRegion').textContent =\n    `${plan.name}、見積総額 ${formattedTotal}。期間 ${pCoeff}、競合 ${cCoeff}、業界 ${iCoeff}、メディア ${mCoeff}、ランク ${rCoeff}、マージン ${marginCoeff}。`;\n}\n\n// ═══════════════════════════════════════\n// INPUT FORMAT\n// ═══════════════════════════════════════\ndocument.getElementById('baseFee').addEventListener('input', function() {\n  let raw = this.value.replace(/[^0-9]/g, '');\n  if (raw) this.value = parseInt(raw).toLocaleString('ja-JP');\n  calculate();\n});\n\n// ═══════════════════════════════════════\n// INIT\n// ═══════════════════════════════════════\ntry {\n  syncCurrentYear();\n  renderCards();\n  calculate();\n  console.log('✅ 初期化完了: カード数 =', document.querySelectorAll('.coeff-card').length);\n} catch(e) {\n  console.error('❌ 初期化エラー:', e);\n}\n</script>\n</body>\n</html>\n","numLines":148,"startLine":800,"totalLines":947}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FdjqHLcRhnEApPSpxma9eY","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I have a full picture of both files. Let me analyze the code thoroughly and identify issues to fix. Here's my analysis:\n\n## Issues Found\n\n### Critical / Bug Issues\n\n1. **Symlink problem for Netlify**: `gokko-ad-pricing.html -> index.html` — Netlify does NOT follow symlinks in static deployments. This will cause a 404 for `/gokko-ad-pricing.html`. Need to replace with actual file copy or redirect.\n\n2. **Hero badge year hardcoded**: `hero-badge` says \"Advertising Menu 2025\" in both files. The `syncCurrentYear` only updates `.copyright-year` in the footer but not the hero badge year. \n\n3. **XSS vulnerability in renderCards()**: The `opt.label` and `opt.desc` values are inserted via string interpolation into innerHTML without escaping. While currently the data is hardcoded (not user input), this is still a bad pattern. However, since it's all static data, this is low risk. I'll note it but not change it as it's static data.\n\n4. **baseFee input allows empty value to show NaN behavior**: When the user clears the input completely, `raw` becomes empty string, `parseInt('')` returns NaN, and the `|| 0` fallback catches it but then the formatting line won't execute properly because NaN doesn't format well with `toLocaleString`.\n\n5. **`parseInt` without radix**: `parseInt(btn.dataset.plan)` and `parseInt(el.dataset.idx)` don't specify radix 10, which could theoretically cause issues with leading zeros in very old engines, though these particular values (0-3 for plans, 0-7 for options) are safe.\n\n### Medium Issues\n\n6. **JS duplication between files**: The PLANS, MARGIN, RANK, renderCards, calculate, and other functions are completely duplicated across files, which is the biggest maintenance headache. I should extract the shared logic into an external file.\n\n7. **focus**\n\n-visible outline colors look correct — the hero section uses white outlines for the dark background, while the coefficient section uses dark outlines for its light background, so the specificity is working as intended.\n\nThere are a few minor issues I'm noticing: some unused CSS variables like `--selected-bg` and `--selected-text` that were defined but never referenced, missing SEO metadata tags, and the Netlify symlink deployment issue which is the most critical problem to solve.\n\nThe real opportunity here is consolidating the duplicated JavaScript across both files — there's about 350 lines of identical code handling the plans data, margin calculations, ranking logic, and card rendering that could be extracted into a shared module. I should also properly resolve the symlink issue instead of relying on it for deployment.\n\nMy approach: extract all the shared logic and data into a `shared.js` file, update both HTML files to import it and keep only their specific initialization code, replace the symlink with a proper redirect or file, make the year dynamic in the hero badge, and clean up those unused CSS variables.\n\nI'm second-guessing whether extracting to shared.js is worth the architectural shift, but the Codex partner flagged JS duplication as a future task, so doing it now has real value. Since these are static files without a build pipeline, a simple `<script src=\"shared.js\">` approach works fine for hosting.\n\nThe main risk is ensuring the DOM elements exist before the shared script runs, but that's manageable with proper script ordering.\n\nI'm thinking the cleanest approach is to have shared.js export an initialization function that handles all the common setup — plan selector events, baseFee input listeners, and the core simulator logic — while each HTML file keeps its own minimal init call. Calls renderCards() and calculate()\n\nAnd each HTML file just calls `initSimulator()` after the DOM is ready (or places the script at the end).\n\nFor index.html, the auth logic remains inline, and it calls `initSimulator()` only after successful auth (or immediately if already authenticated). Wait, no — looking at the current code, the simulator initializes immediately regardless of auth state (the init is in the second `<script>` block). The login overlay just hides/shows the content visually. So the init runs immediately.\n\nOK, so I'll extract the shared logic into shared.js with state management, the card rendering, click handlers, and the calculate function. Then index.html adds the shared script before its auth logic, and preview.html just adds the shared script and calls the init functions.\n\nThe two files will be nearly identical after this refactor — they'll only differ in the auth overlay HTML, auth JS, and the default visibility of the app content. I could use a symlink or a `_redirects` file for Netlify to handle preview.html, or just keep both files since they'll be so minimal now.\n\nActually, I realize the symlink approach was trying to avoid duplication of the entire HTML structure. But with shared.js extracted, the HTML files themselves become mostly just the auth overlay differences. Let me check what's actually different between the two files after extracting shared.js...\n\nThe simulator HTML structure (hero, plan-selector, coeffGrid, cards, etc.) is identical in both. The only differences are the auth overlay and the default visibility of `.app-content`. So keeping both files does introduce some duplication, but it's minimal and avoids needing a build step or server-side logic.\n\nI think the cleanest approach without a build step is to keep both files as real files, extract shared.js, and accept the small amount of HTML duplication. Or use a `_redirects` file on Netlify to serve index.html when preview.html is requested, but that changes the URL which might not be desired.\n\nLet me go with: extract shared.js, keep both HTML files, remove the symlink.\n\nI'm realizing the original setup had `gokko-ad-pricing.html` as a symlink to `index.html` because they were identical. But now with the auth overlay, they're not identical anymore, so the symlink doesn't make sense anyway. The preview version needs to be a separate file without the auth logic.\n\nSo the final structure is: `index.html` (with auth), `preview.html` (without auth), and `shared.js` (all the simulator logic). Both HTML files will have some duplicated HTML structure, but that's acceptable without a build step.\n\nFor the year issue, I should make the hero badge year dynamic by adding a span with a class that gets updated by the existing `syncCurrentYear()` function, or create a new function to handle it.\n\nLooking at what else needs fixing: those unused CSS variables `--selected-bg` and `--selected-text` should go, and I'm noticing the CSS is still duplicated across both files. Extracting it into a shared stylesheet alongside shared JavaScript would be cleaner. My approach is to create shared CSS and JS files, strip down both HTML files to only their unique pieces, replace the symlink with a Netlify `_redirects` rule, make the year dynamic, and remove the unused variables. This refactor eliminates a lot of duplication.\n\nNow I'm examining the CSS more carefully — the two files are nearly identical except for login-specific styles in the auth page and how they handle the app-content visibility. So the shared stylesheet can hold everything generic, leaving just the login styles and visibility toggles in their respective files. Let me start building this out.\n\nI'm thinking through the JavaScript extraction more carefully since it's riskier than CSS. The global state like `currentPlan` and the core functions need to stay accessible across both files, so I'll need to be deliberate about what goes into the shared module and what stays local. Let me proceed with creating the shared files and then carefully update both HTML pages.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":15754,"cache_read_input_tokens":44540,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":15754},"output_tokens":12,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"99417205-2b4a-4073-8fe9-e262d832a3a7","uuid":"f2c870a7-0de1-49a2-8a8f-44d5a04c813e"}
