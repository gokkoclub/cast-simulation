956\t\n957\t// ═══════════════════════════════════════\n958\t// PLAN SELECTOR\n959\t// ═══════════════════════════════════════\n960\tfunction selectPlan(btn) {\n961\t  currentPlan = parseInt(btn.dataset.plan);\n962\t  document.querySelectorAll('.plan-btn').forEach(b => {\n963\t    b.classList.remove('active');\n964\t    b.setAttribute('aria-checked', 'false');\n965\t  });\n966\t  btn.classList.add('active');\n967\t  btn.setAttribute('aria-checked', 'true');\n968\t  // Reset selections\n969\t  state.period = 0; state.competition = 0; state.industry = 0; state.media = [0]; state.rank = 0; state.margin = 0;\n970\t  renderCards();\n971\t  calculate();\n972\t}\n973\t\n974\tdocument.querySelectorAll('.plan-btn').forEach(btn => {\n975\t  btn.addEventListener('click', () => selectPlan(btn));\n976\t  btn.addEventListener('keydown', (e) => {\n977\t    if (e.key === 'Enter' || e.key === ' ') {\n978\t      e.preventDefault();\n979\t      selectPlan(btn);\n980\t    }\n981\t  });\n982\t});\n983\t\n984\t// ═══════════════════════════════════════\n985\t// RENDER\n986\t// ═══════════════════════════════════════\n987\tfunction getCoeffCategories() {\n988\t  const plan = PLANS[currentPlan];\n989\t  return [\n990\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n991\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n992\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n993\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n994\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n995\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n996\t  ];\n997\t}\n998\t\n999\tfunction renderCards() {\n1000\t  const grid = document.getElementById('coeffGrid');\n1001\t  grid.innerHTML = '';\n1002\t  const cats = getCoeffCategories();\n1003\t\n1004\t  cats.forEach(cat => {\n1005\t    const card = document.createElement('div');\n1006\t    card.className = 'coeff-card';\n1007\t    const isCheck = cat.type === 'checkbox';\n1008\t\n1009\t    let html = '';\n1010\t    cat.options.forEach((opt, i) => {\n1011\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n1012\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n1013\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n1014\t      const role = isCheck ? 'checkbox' : 'radio';\n1015\t      const ariaChecked = sel ? 'true' : 'false';\n1016\t      const ariaDisabled = opt.base ? 'true' : 'false';\n1017\t      const tabIndex = opt.base ? '-1' : '0';\n1018\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n1019\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n1020\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n1021\t    });\n1022\t\n1023\t    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n1024\t    const groupRole = isCheck ? 'group' : 'radiogroup';\n1025\t\n1026\t    card.innerHTML = `<div class=\"coeff-header\">\n1027\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n1028\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n1029\t\n1030\t    grid.appendChild(card);\n1031\t  });\n1032\t\n1033\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n1034\t    el.addEventListener('click', handleClick);\n1035\t    el.addEventListener('keydown', (e) => {\n1036\t      if (e.key === 'Enter' || e.key === ' ') {\n1037\t        e.preventDefault();\n1038\t        handleClick(e);\n1039\t      }\n1040\t    });\n1041\t  });\n1042\t}\n1043\t\n1044\tfunction handleClick(e) {\n1045\t  const el = e.currentTarget;\n1046\t  const catId = el.dataset.cat;\n1047\t  const idx = parseInt(el.dataset.idx);\n1048\t  const cats = getCoeffCategories();\n1049\t  const cat = cats.find(c => c.id === catId);\n1050\t\n1051\t  if (cat.type === 'checkbox') {\n1052\t    if (el.dataset.base) return;\n1053\t    const a = state[catId];\n1054\t    const p = a.indexOf(idx);\n1055\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n1056\t  } else {\n1057\t    state[catId] = idx;\n1058\t  }\n1059\t  renderCards();\n1060\t  calculate();\n1061\t}\n1062\t\n1063\t// ═══════════════════════════════════════\n1064\t// CALCULATE\n1065\t// ═══════════════════════════════════════\n1066\tfunction calculate() {\n1067\t  const plan = PLANS[currentPlan];\n1068\t  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n1069\t\n1070\t  const pCoeff = plan.period[state.period].coeff;\n1071\t  const cCoeff = plan.competition[state.competition].coeff;\n1072\t  const iCoeff = plan.industry[state.industry].coeff;\n1073\t\n1074\t  let mSum = 0;\n1075\t  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n1076\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n1077\t\n1078\t  const rCoeff = RANK[state.rank].coeff;\n1079\t  const marginCoeff = MARGIN[state.margin].coeff;\n1080\t\n1081\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n1082\t\n1083\t  // Badge\n1084\t  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n1085\t\n1086\t  // Breakdown\n1087\t  const bd = document.getElementById('resultBreakdown');\n1088\t  const chips = [\n1089\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n1090\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n1091\t  ];\n1092\t  bd.innerHTML = chips.map((c, i) =>\n1093\t    `<span class=\"result-chip\">${c.l} <span>×${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">×</span>' : ''}`\n1094\t  ).join('');\n1095\t\n1096\t  const formattedTotal = '¥' + Math.round(total).toLocaleString('ja-JP');\n1097\t  document.getElementById('resultValue').textContent = formattedTotal;\n1098\t  document.getElementById('resultLiveRegion').textContent =\n1099\t    `${plan.name}、見積総額 ${formattedTotal}。期間 ${pCoeff}、競合 ${cCoeff}、業界 ${iCoeff}、メディア ${mCoeff}、ランク ${rCoeff}、マージン ${marginCoeff}。`;\n1100\t}\n1101\t\n1102\t// ═══════════════════════════════════════\n1103\t// INPUT FORMAT\n1104\t// ═══════════════════════════════════════\n1105\tdocument.getElementById('baseFee').addEventListener('input', function() {\n1106\t  let raw = this.value.replace(/[^0-9]/g, '');\n1107\t  if (raw) this.value = parseInt(raw).toLocaleString('ja-JP');\n1108\t  calculate();\n1109\t});\n1110\t\n1111\t// ═══════════════════════════════════════\n1112\t// INIT\n1113\t// ═══════════════════════════════════════\n1114\ttry {\n1115\t  renderCards();\n1116\t  calculate();\n1117\t  console.log('✅ 初期化完了: カード数 =', document.querySelectorAll('.coeff-card').length);\n1118\t} catch(e) {\n1119\t  console.error('❌ 初期化エラー:', e);\n1120\t}\n1121\t</script>\n1122\t</body>\n1123\t</html>\n1124\t"}]},"parent_tool_use_id":null,"session_id":"99417205-2b4a-4073-8fe9-e262d832a3a7","uuid":"0410b2db-f8a0-4e4f-b856-0267892b629f","timestamp":"2026-04-09T09:34:01.737Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ucmuller/workspace/cast-simulation/index.html","content":"      { label: '金融・保険',           coeff: 1.6, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 1.8, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 2.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n      { label: 'Instagram',         