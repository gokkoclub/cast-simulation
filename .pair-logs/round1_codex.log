{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"nl -ba gokko-ad-pricing-preview.html | sed -n '852,930p'\"","aggregated_output":"   852\t// ═══════════════════════════════════════\n   853\t// CALCULATE\n   854\t// ═══════════════════════════════════════\n   855\tfunction calculate() {\n   856\t  const plan = PLANS[currentPlan];\n   857\t  const cats = getCoeffCategories();\n   858\t  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n   859\t\n   860\t  const pCoeff = plan.period[state.period].coeff;\n   861\t  const cCoeff = plan.competition[state.competition].coeff;\n   862\t  const iCoeff = plan.industry[state.industry].coeff;\n   863\t\n   864\t  let mSum = 0;\n   865\t  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n   866\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n   867\t\n   868\t  const rCoeff = RANK[state.rank].coeff;\n   869\t  const marginCoeff = MARGIN[state.margin].coeff;\n   870\t\n   871\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n   872\t\n   873\t  // Badge\n   874\t  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n   875\t\n   876\t  // Breakdown\n   877\t  const bd = document.getElementById('resultBreakdown');\n   878\t  const chips = [\n   879\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n   880\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n   881\t  ];\n   882\t  bd.innerHTML = chips.map((c, i) =>\n   883\t    `<span class=\"result-chip\">${c.l} <span>×${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">×</span>' : ''}`\n   884\t  ).join('');\n   885\t\n   886\t  document.getElementById('resultValue').textContent = '¥' + Math.round(total).toLocaleString('ja-JP');\n   887\t}\n   888\t\n   889\t// ═══════════════════════════════════════\n   890\t// INPUT FORMAT\n   8