ff: 2.2, desc: '特殊な規制対象業界' },\n   671\t    ],\n   672\t    media: [\n   673\t      { label: 'TikTok（基本）',       coeff: 1.0,  desc: '基本配信面', base: true },\n   674\t      { label: 'Instagram',           coeff: 0.18, desc: 'TikTokに加算' },\n   675\t      { label: 'YouTube（Short含む）', coeff: 0.25, desc: 'TikTokに加算' },\n   676\t      { label: 'X（旧Twitter）',       coeff: 0.15, desc: 'TikTokに加算' },\n   677\t      { label: 'LINE VOOM',           coeff: 0.15, desc: 'TikTokに加算' },\n   678\t      { label: 'バナー（静止画）',     coeff: 0.07, desc: 'TikTokに加算' },\n   679\t      { label: 'Web広告（HP埋込等）',  coeff: 0.3,  desc: 'TikTokに加算' },\n   680\t      { label: 'テレビCM',            coeff: 0.45, desc: 'TikTokに加算' },\n   681\t    ],\n   682\t    mediaCap: 2.0,\n   683\t  },\n   684\t  // ── PLAN 3: プレミアムプラン（アップセル）──\n   685\t  {\n   686\t    name: 'プレミアムプラン',\n   687\t    nameEn: 'PREMIUM',\n   688\t    period: [\n   689\t      { label: '1ヶ月', coeff: 1.5, desc: 'お試し配信' },\n   690\t      { label: '3ヶ月', coeff: 1.8, desc: '短期集中キャンペーン' },\n   691\t      { label: '6ヶ月', coeff: 2.4, desc: '標準的な広告契約' },\n   692\t      { label: '1年',   coeff: 3.6, desc: '年間継続展開' },\n   693\t      { label: '2年',   coeff: 5.4, desc: '長期ブランド戦略' },\n   694\t      { label: '無期限', coeff: 7.2, desc: '恒久的な利用権' },\n   695\t    ],\n   696\t    competition: [\n   697\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n   698\t      { label: '商品競合のみ', coeff: 2.0, desc: '同一商品カテゴリを排除' },\n   699\t      { label: '業界競合',     coeff: 2.5, desc: '同一業界全体を排除' },\n   700\t      { label: '全競合排除',   coeff: 3.0, desc: 'すべての競合を排除' },\n   701\t    ],\n   702\t    industry: [\n   703\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n   704\t      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n   705\t      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n   706\t      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n   707\t      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n   708\t      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n   709\t    ],\n   710\t    media: [\n   711\t      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n   712\t      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n   713\t      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n   714\t      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n   715\t      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n   716\t      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n   717\t      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n   718\t      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n   719\t    ],\n   720\t    mediaCap: 3.0,\n   721\t  },\n   722\t];\n   723\t\n   724\t// GOKKO Margin is shared across all plans (3 tiers)\n   725\tconst MARGIN = [\n   726\t  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n   727\t  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n   728\t  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n   729\t];\n   730\t\n   731\t// Talent rank is shared across all plans\n   732\tconst RANK = [\n   733\t  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n   734\t  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n   735\t  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n   736\t  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n   737\t  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n   738\t  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n   739\t  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n   740\t  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n   741\t];\n   742\t\n   743\t// ═══════════════════════════════════════\n   744\t// STATE\n   745\t// ═══════════════════════════════════════\n   746\tlet currentPlan = 2; // default: スタンダード\n   747\tconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n   748\t\n   749\t// ═══════════════════════════════════════\n   750\t// PLAN SELECTOR\n   751\t// ═══════════════════════════════════════\n   752\tfunction selectPlan(btn) {\n   753\t  currentPlan = parseInt(btn.dataset.plan);\n   754\t  document.querySelectorAll('.plan-btn').forEach(b => {\n   755\t    b.classList.remove('active');\n   756\t    b.setAttribute('aria-checked', 'false');\n   757\t  });\n   758\t  btn.classList.add('active');\n   759\t  btn.setAttribute('aria-checked', 'true');\n   760\t  // Reset selections\n   761\t  state.period = 0; state.competition = 0; state.industry = 0; state.media = [0]; state.rank = 0; state.margin = 0;\n   762\t  renderCards();\n   763\t  calculate();\n   764\t}\n   765\t\n   766\tdocument.querySelectorAll('.plan-btn').forEach(btn => {\n   767\t  btn.addEventListener('click', () => selectPlan(btn));\n   768\t  btn.addEventListener('keydown', (e) => {\n   769\t    if (e.key === 'Enter' || e.key === ' ') {\n   770\t      e.preventDefault();\n   771\t      selectPlan(btn);\n   772\t    }\n   773\t  });\n   774\t});\n   775\t\n   776\t// ═══════════════════════════════════════\n   777\t// RENDER\n   778\t// ═══════════════════════════════════════\n   779\tfunction getCoeffCategories() {\n   780\t  const plan = PLANS[currentPlan];\n   781\t  return [\n   782\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n   783\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n   784\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n   785\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n   786\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n   787\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n   788\t  ];\n   789\t}\n   790\t\n   791\tfunction renderCards() {\n   792\t  const grid = document.getElementById('coeffGrid');\n   793\t  grid.innerHTML = '';\n   794\t  const cats = getCoeffCategories();\n   795\t\n   796\t  cats.forEach(cat => {\n   797\t    const card = document.createElement('div');\n   798\t    card.className = 'coeff-card';\n   799\t    const isCheck = cat.type === 'checkbox';\n   800\t\n   801\t    let html = '';\n   802\t    cat.options.forEach((opt, i) => {\n   803\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n   804\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n   805\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n   806\t      const role = isCheck ? 'checkbox' : 'radio';\n   807\t      const ariaChecked = sel ? 'true' : 'false';\n   808\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" tabindex=\"0\">\n   809\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n   810\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n   811\t    });\n   812\t\n   813\t    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n   814\t\n   815\t    card.innerHTML = `<div class=\"coeff-header\">\n   816\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n   817\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\">${html}</div>${capNote}`;\n   818\t\n   819\t    grid.appendChild(card);\n   820\t  });\n   821\t\n   822\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n   823\t    el.addEventListener('click', handleClick);\n   824\t    el.addEventListener('keydown', (e) => {\n   825\t      if (e.key === 'Enter' || e.key === ' ') {\n   826\t        e.preventDefault();\n   827\t        handleClick(e);\n   828\t      }\n   829\t    });\n   830\t  });\n   831\t}\n   832\t\n   833\tfunction handleClick(e) {\n   834\t  const el = e.currentTarget;\n   835\t  const catId = el.dataset.cat;\n   836\t  const idx = parseInt(el.dataset.idx);\n   837\t  const cats = getCoeffCategories();\n   838\t  const cat = cats.find(c => c.id === catId);\n   839\t\n   840\t  if (cat.type === 'checkbox') {\n   841\t    if (el.dataset.base) return;\n   842\t    const a = state[catId];\n   843\t    const p = a.indexOf(idx);\n   844\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n   845\t  } else {\n   846\t    state[catId] = idx;\n   847\t  }\n   848\t  renderCards();\n   849\t  calculate();\n   850\t}\n   851\t\n   852\t// ═══════════════════════════════════════\n   853\t// CALCULATE\n   854\t// ═══════════════════════════════════════\n   855\tfunction calculate() {\n   856\t  const plan = PLANS[currentPlan];\n   857\t  const cats = getCoeffCategories();\n   858\t  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n   859\t\n   860\t  const pCoeff = plan.period[state.period].coeff;\n","exit_code":0,"status":"completed"}}
