5\t    width: 90%;\n   476\t    box-shadow: 0 2px 20px rgba(0,0,0,0.06);\n   477\t  }\n   478\t  .login-card h2 {\n   479\t    font-size: 26px;\n   480\t    font-weight: 900;\n   481\t    margin-bottom: 6px;\n   482\t    color: var(--black);\n   483\t  }\n   484\t  .login-card .login-sub {\n   485\t    font-size: 13px;\n   486\t    color: var(--gray-500);\n   487\t    margin-bottom: 32px;\n   488\t  }\n   489\t  .login-box {\n   490\t    background: var(--gray-100);\n   491\t    border-radius: 14px;\n   492\t    padding: 28px 24px;\n   493\t    margin-bottom: 20px;\n   494\t  }\n   495\t  .login-box p {\n   496\t    font-size: 13px;\n   497\t    color: var(--gray-600);\n   498\t    margin-bottom: 16px;\n   499\t  }\n   500\t  .google-btn {\n   501\t    display: inline-flex;\n   502\t    align-items: center;\n   503\t    gap: 10px;\n   504\t    background: var(--white);\n   505\t    border: 1px solid var(--card-border);\n   506\t    border-radius: 10px;\n   507\t    padding: 12px 28px;\n   508\t    font-size: 14px;\n   509\t    font-weight: 500;\n   510\t    color: var(--black);\n   511\t    cursor: pointer;\n   512\t    transition: all 0.2s;\n   513\t    font-family: var(--font-ja);\n   514\t  }\n   515\t  .google-btn:hover {\n   516\t    border-color: var(--gray-400);\n   517\t    box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n   518\t  }\n   519\t  .google-btn svg { width: 18px; height: 18px; }\n   520\t  .login-domain {\n   521\t    font-size: 12px;\n   522\t    color: var(--gray-400);\n   523\t  }\n   524\t  .login-error {\n   525\t    color: #d32f2f;\n   526\t    font-size: 12px;\n   527\t    margin-top: 12px;\n   528\t    display: none;\n   529\t  }\n   530\t\n   531\t  .app-content { display: none; }\n   532\t  .app-content.visible { display: block; }\n   533\t</style>\n   534\t</head>\n   535\t<body>\n   536\t\n   537\t<!-- ── Login Overlay ── -->\n   538\t<div class=\"login-overlay\" id=\"loginOverlay\">\n   539\t  <div class=\"login-card\">\n   540\t    <h2>広告料金シミュレーター</h2>\n   541\t    <p class=\"login-sub\">縦型ショートドラマ 広告利用メニュー</p>\n   542\t    <div class=\"login-box\">\n   543\t      <p>gokkoclub.jp のアカウントでログインしてください</p>\n   544\t      <button class=\"google-btn\" id=\"googleLoginBtn\">\n   545\t        <svg viewBox=\"0 0 48 48\"><path fill=\"#EA4335\" d=\"M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z\"/><path fill=\"#4285F4\" d=\"M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z\"/><path fill=\"#FBBC05\" d=\"M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z\"/><path fill=\"#34A853\" d=\"M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z\"/></svg>\n   546\t        Google でログイン\n   547\t      </button>\n   548\t      <p class=\"login-error\" id=\"loginError\">@gokkoclub.jp のメールアドレスでログインしてください</p>\n   549\t    </div>\n   550\t    <p class=\"login-domain\">@gokkoclub.jp のメールアドレスが必要です</p>\n   551\t  </div>\n   552\t</div>\n   553\t\n   554\t<!-- ── App Content (hidden until login) ── -->\n   555\t<div class=\"app-content\" id=\"appContent\">\n   556\t\n   557\t<!-- ── Hero ── -->\n   558\t<section class=\"hero\">\n   559\t  <div class=\"hero-badge\">GOKKO Inc. — Advertising Menu 2025</div>\n   560\t  <h1>Ad Pricing<br>Simulator</h1>\n   561\t  <p>縦型ショートドラマ広告利用の料金を、プランと各係数からリアルタイムでシミュレーション</p>\n   562\t\n   563\t  <div class=\"plan-selector\" id=\"planSelector\" role=\"radiogroup\" aria-label=\"プラン選択\">\n   564\t    <div class=\"plan-btn\" data-plan=\"0\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n   565\t      <span class=\"plan-num\">PLAN 01</span>\n   566\t      <span class=\"plan-name\">ライトプラン</span>\n   567\t      <span class=\"plan-sub\">フック重視</span>\n   568\t    </div>\n   569\t    <div class=\"plan-btn\" data-plan=\"1\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n   570\t      <span class=\"plan-num\">PLAN 02</span>\n   571\t      <span class=\"plan-name\">ベーシックプラン</span>\n   572\t      <span class=\"plan-sub\">実稼働費回収</span>\n   573\t    </div>\n   574\t    <div class=\"plan-btn active\" data-plan=\"2\" role=\"radio\" aria-checked=\"true\" tabindex=\"0\">\n   575\t      <span class=\"plan-recommended\">RECOMMENDED</span>\n   576\t      <span class=\"plan-num\">PLAN 03</span>\n   577\t      <span class=\"plan-name\">スタンダードプラン</span>\n   578\t      <span class=\"plan-sub\">バランス型</span>\n   579\t    </div>\n   580\t    <div class=\"plan-btn\" data-plan=\"3\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n   581\t      <span class=\"plan-num\">PLAN 04</span>\n   582\t      <span class=\"plan-name\">プレミアムプラン</span>\n   583\t      <span class=\"plan-sub\">アップセル</span>\n   584\t    </div>\n   585\t  </div>\n   586\t</section>\n   587\t\n   588\t<!-- ── Formula Bar ── -->\n   589\t<div class=\"formula-bar\">\n   590\t  <span>総額</span> = 基本出演料 × 使用期間 × 競合排除 × 業界 × メディア × 出演者ランク × マージン\n   591\t</div>\n   592\t\n   593\t<!-- ── Main ── -->\n   594\t<div class=\"container\">\n   595\t\n   596\t  <!-- Base Fee -->\n   597\t  <section class=\"section\">\n   598\t    <div class=\"section-label\">Base Fee</div>\n   599\t    <div class=\"section-title\">基本出演料を入力</div>\n   600\t    <div class=\"base-fee-card\">\n   601\t      <label>ショートドラマ出演時のキャスティング費（税別）</label>\n   602\t      <div class=\"input-row\">\n   603\t        <span>¥</span>\n   604\t        <input type=\"text\" class=\"base-fee-input\" id=\"baseFee\" placeholder=\"100,000\" value=\"100,000\">\n   605\t      </div>\n   606\t    </div>\n   607\t  </section>\n   608\t\n   609\t  <!-- Coefficients -->\n   610\t  <section class=\"section\">\n   611\t    <div class=\"section-label\">Coefficients</div>\n   612\t    <div class=\"section-title\">各係数を選択してください</div>\n   613\t    <div class=\"coeff-grid\" id=\"coeffGrid\"></div>\n   614\t  </section>\n   615\t\n   616\t  <!-- Reference -->\n   617\t  <section class=\"section\">\n   618\t    <div class=\"section-label\">Reference</div>\n   619\t    <div class=\"section-title\">出演者ランク別 基本出演料の目安</div>\n   620\t    <div class=\"ref-table-wrap\">\n   621\t      <table class=\"ref-table\">\n   622\t        <thead>\n   623\t          <tr><th>ランク</th><th>係数</th><th>説明</th><th>基本出演料目安</th></tr>\n   624\t        </thead>\n   625\t        <tbody>\n   626\t          <tr><td>新人A</td><td>×0.8</td><td>GOKKO専属新人</td><td>5万円</td></tr>\n   627\t          <tr><td>新人B</td><td>×1.0</td><td>一般新人キャスト</td><td>8〜12万円</td></tr>\n   628\t          <tr><td>準中堅</td><td>×1.8</td><td>実績ある若手</td><td>15〜25万円</td></tr>\n   629\t          <tr><td>中堅A</td><td>×2.5</td><td>中堅タレント</td><td>30〜40万円</td></tr>\n   630\t          <tr><td>中堅B</td><td>×3.5</td><td>人気中堅タレント</td><td>50〜80万円</td></tr>\n   631\t          <tr><td>準有名</td><td>×5.0</td><td>知名度上昇中</td><td>80〜120万円</td></tr>\n   632\t          <tr><td>有名A</td><td>×8.0</td><td>有名タレント</td><td>150〜300万円</td></tr>\n   633\t          <tr><td>有名S</td><td>×12.0</td><td>トップクラス</td><td>500万円以上</td></tr>\n   634\t        </tbody>\n   635\t      </table>\n   636\t    </div>\n   637\t  </section>\n   638\t</div>\n   639\t\n   640\t<!-- ── Sticky Result ── -->\n   641\t<div class=\"result-panel\" id=\"resultPanel\">\n   642\t  <div class=\"result-inner\">\n   643\t    <div class=\"result-left\">\n   644\t      <div class=\"result-plan-badge\" id=\"resultPlanBadge\">STANDARD</div>\n   645\t      <div class=\"result-breakdown\" id=\"resultBreakdown\"></div>\n   646\t    </div>\n   647\t    <div class=\"result-total\">\n   648\t      <div class=\"result-total-label\">Estimated Total</div>\n   649\t      <div class=\"result-total-value\" id=\"resultValue\">¥0</div>\n   650\t    </div>\n   651\t  </div>\n   652\t</div>\n   653\t\n   654\t<!-- ── Footer ── -->\n   655\t<footer class=\"footer\">\n   656\t  © 2025 GOKKO Inc. All rights reserved. ｜ 本料金表は参考価格です。正式なお見積りは別途ご相談ください。\n   657\t</footer>\n   658\t\n   659\t</div><!-- /app-content -->\n   660\t\n   661\t<script>\n   662\t// ═══════════════════════════════════════\n   663\t// GOOGLE AUTH\n   664\t// ═══════════════════════════════════════\n   665\t// ★★★ ここにGoogle Cloud ConsoleのクライアントIDを入れてください ★★★\n   666\tconst GOOGLE_CLIENT_ID = '777058430626-nla9pd956ss4t7jrchf58ebc0u614rcq.apps.googleusercontent.com';\n   667\tconst ALLOWED_DOMAIN = 'gokkoclub.jp';\n   668\t\n   669\tlet cachedAccessToken = null;\n   670\t\n   671\tfunction showApp() {\n   672\t  document.getElementById('loginOverlay').classList.add('hidden');\n   673\t  document.getElementById('appContent').classList.add('visible');\n   674\t}\n   675\t\n   676\tfunction handleGoogleLogin() {\n   677\t  try {\n   678\t    const client = google.accounts.oauth2.initTokenClient({\n   679\t      client_id: GOOGLE_CLIENT_ID,\n   680\t      scope: 'email profile',\n   681\t      callback: (response) => {\n   682\t        if (response.access_token) {\n   683\t          cachedAccessToken = response.access_token;\n   684\t          verifyAndShowApp(response.access_token);\n   685\t        }\n   686\t      },\n   687\t    });\n   688\t    client.requestAccessToken();\n   689\t  } catch(e) {\n   690\t    console.error('Google Auth error:', e);\n   691\t    alert('Googleログインの読み込みに失敗しました。https:// でアクセスしてください。');\n   692\t  }\n   693\t}\n   694\t\n   695\tfunction verifyAndShowApp(accessToken) {\n   696\t  fetch('https://www.googleapis.com/oauth2/v3/userinfo', {\n   697\t    headers: { Authorization: 'Bearer ' + accessToken }\n   698\t  })\n   699\t  .then(r => {\n   700\t    if (!r.ok) throw new Error('userinfo request failed: ' + r.status);\n   701\t    return r.json();\n   702\t  })\n   703\t  .then(user => {\n   704\t    if (user.email && user.email.endsWith('@' + ALLOWED_DOMAIN)) {\n   705\t      sessionStorage.setItem('gokko_access_token', accessToken);\n   706\t      showApp();\n   707\t    } else {\n   708\t      document.getElementById('loginError').style.display = 'block';\n   709\t    }\n   710\t  })\n   711\t  .catch(err => {\n   712\t    console.error('Auth verification failed:', err);\n   713\t    sessionStorage.removeItem('gokko_access_token');\n   714\t    document.getElementById('loginError').style.display = 'block';\n   715\t  });\n   716\t}\n   717\t\n   718\t// Check existing session — re-verify token with Google\n   719\twindow.addEventListener('DOMContentLoaded', () => {\n   720\t  document.getElementById('googleLoginBtn').addEventListener('click', handleGoogleLogin);\n   721\t  const savedToken = sessionStorage.getItem('gokko_access_token');\n   722\t  if (savedToken) {\n   723\t    verifyAndShowApp(savedToken);\n   724\t  }\n   725\t});\n   726\t</script>\n   727\t\n   728\t<script>\n   729\t// ═══════════════════════════════════════\n   730\t// PLAN DATA — 4 plans × 5 coefficient categories\n   731\t// ═══════════════════════════════════════\n   732\tconst PLANS = [\n   733\t  // ── PLAN 0: ライトプラン（フック重視）──\n   734\t  {\n   735\t    name: 'ライトプラン',\n   736\t    nameEn: 'LIGHT',\n   737\t    period: [\n   738\t      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n   739\t      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n   740\t      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n   741\t      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n   742\t      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n   743\t      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n   744\t    ],\n   745\t    competition: [\n   746\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n   747\t      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n   748\t      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n   749\t      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n   750\t    ],\n   751\t    industry: [\n   752\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n   753