\t\n   310\t  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n   311\t\n   312\t  const bd = document.getElementById('resultBreakdown');\n   313\t  const chips = [\n   314\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n   315\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n   316\t  ];\n   317\t  bd.innerHTML = chips.map((c, i) =>\n   318\t    `<span class=\"result-chip\">${c.l} <span>\\u00d7${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">\\u00d7</span>' : ''}`\n   319\t  ).join('');\n   320\t\n   321\t  const formattedTotal = '\\u00a5' + Math.round(total).toLocaleString('ja-JP');\n   322\t  document.getElementById('resultValue').textContent = formattedTotal;\n   323\t  document.getElementById('resultLiveRegion').textContent =\n   324\t    `${plan.name}\\u3001\\u898b\\u7a4d\\u7dcf\\u984d ${formattedTotal}\\u3002\\u671f\\u9593 ${pCoeff}\\u3001\\u7af6\\u5408 ${cCoeff}\\u3001\\u696d\\u754c ${iCoeff}\\u3001\\u30e1\\u30c7\\u30a3\\u30a2 ${mCoeff}\\u3001\\u30e9\\u30f3\\u30af ${rCoeff}\\u3001\\u30de\\u30fc\\u30b8\\u30f3 ${marginCoeff}\\u3002`;\n   325\t}\n   326\t\n   327\t// ═══════════════════════════════════════\n   328\t// INIT\n   329\t// ═══════════════════════════════════════\n   330\tfunction initSimulator() {\n   331\t  // Plan selector events\n   332\t  document.querySelectorAll('.plan-btn').forEach(btn => {\n   333\t    btn.addEventListener('click', () => selectPlan(btn));\n   334\t    btn.addEventListener('keydown', (e) => {\n   335\t      if (e.key === 'Enter' || e.key === ' ') {\n   336\t        e.preventDefault();\n   337\t        selectPlan(btn);\n   338\t      }\n   339\t    });\n   340\t  });\n   341\t\n   342\t  // Base fee input formatting\n   343\t  document.getElementById('baseFee').addEventListener('input', function() {\n   344\t    let raw = this.value.replace(/[^0-9]/g, '');\n   345\t    if (raw) this.value = parseInt(raw, 10).