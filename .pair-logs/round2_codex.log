{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"/bin/zsh -lc \"nl -ba index.html | sed -n '1,360p'\"","aggregated_output":"     1\t<!DOCTYPE html>\n     2\t<html lang=\"ja\">\n     3\t<head>\n     4\t<meta charset=\"UTF-8\">\n     5\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n     6\t<title>GOKKO | 縦型ショートドラマ 広告利用メニュー</title>\n     7\t<script src=\"https://accounts.google.com/gsi/client\" async defer></script>\n     8\t<link rel=\"stylesheet\" href=\"shared.css\">\n     9\t<style>\n    10\t  /* ── Login Overlay (auth version only) ── */\n    11\t  .login-overlay {\n    12\t    position: fixed;\n    13\t    inset: 0;\n    14\t    z-index: 9999;\n    15\t    background: var(--gray-100);\n    16\t    display: flex;\n    17\t    align-items: center;\n    18\t    justify-content: center;\n    19\t    transition: opacity 0.4s, visibility 0.4s;\n    20\t  }\n    21\t  .login-overlay.hidden {\n    22\t    opacity: 0;\n    23\t    visibility: hidden;\n    24\t    pointer-events: none;\n    25\t  }\n    26\t  .login-card {\n    27\t    background: var(--white);\n    28\t    border-radius: 20px;\n    29\t    padding: 48px 40px;\n    30\t    text-align: center;\n    31\t    max-width: 400px;\n    32\t    width: 90%;\n    33\t    box-shadow: 0 2px 20px rgba(0,0,0,0.06);\n    34\t  }\n    35\t  .login-card h2 {\n    36\t    font-size: 26px;\n    37\t    font-weight: 900;\n    38\t    margin-bottom: 6px;\n    39\t    color: var(--black);\n    40\t  }\n    41\t  .login-card .login-sub {\n    42\t    font-size: 13px;\n    43\t    color: var(--gray-500);\n    44\t    margin-bottom: 32px;\n    45\t  }\n    46\t  .login-box {\n    47\t    background: var(--gray-100);\n    48\t    border-radius: 14px;\n    49\t    padding: 28px 24px;\n    50\t    margin-bottom: 20px;\n    51\t  }\n    52\t  .login-box p {\n    53\t    font-size: 13px;\n    54\t    color: var(--gray-600);\n    55\t    margin-bottom: 16px;\n    56\t  }\n    57\t  .google-btn {\n    58\t    display: inline-flex;\n    59\t    align-items: center;\n    60\t    gap: 10px;\n    61\t    background: var(--white);\n    62\t    border: 1px solid var(--card-border);\n    63\t    border-radius: 10px;\n    64\t    padding: 12px 28px;\n    65\t    font-size: 14px;\n    66\t    font-weight: 500;\n    67\t    color: var(--black);\n    68\t    cursor: pointer;\n    69\t    transition: all 0.2s;\n    70\t    font-family: var(--font-ja);\n    71\t  }\n    72\t  .google-btn:hover {\n    73\t    border-color: var(--gray-400);\n    74\t    box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n    75\t  }\n    76\t  .google-btn:focus-visible {\n    77\t    outline: 3px solid rgba(255,255,255,0.45);\n    78\t    outline-offset: 3px;\n    79\t  }\n    80\t  .google-btn svg { width: 18px; height: 18px; }\n    81\t  .login-domain {\n    82\t    font-size: 12px;\n    83\t    color: var(--gray-400);\n    84\t  }\n    85\t  .login-error {\n    86\t    color: #d32f2f;\n    87\t    font-size: 12px;\n    88\t    margin-top: 12px;\n    89\t    display: none;\n    90\t  }\n    91\t\n    92\t  .app-content { display: none; }\n    93\t  .app-content.visible { display: block; }\n    94\t</style>\n    95\t</head>\n    96\t<body>\n    97\t\n    98\t<!-- ── Login Overlay ── -->\n    99\t<div class=\"login-overlay\" id=\"loginOverlay\">\n   100\t  <div class=\"login-card\">\n   101\t    <h2>広告料金シミュレーター</h2>\n   102\t    <p class=\"login-sub\">縦型ショートドラマ 広告利用メニュー</p>\n   103\t    <div class=\"login-box\">\n   104\t      <p>gokkoclub.jp のアカウントでログインしてください</p>\n   105\t      <button class=\"google-btn\" id=\"googleLoginBtn\">\n   106\t        <svg viewBox=\"0 0 48 48\"><path fill=\"#EA4335\" d=\"M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z\"/><path fill=\"#4285F4\" d=\"M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z\"/><path fill=\"#FBBC05\" d=\"M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z\"/><path fill=\"#34A853\" d=\"M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z\"/></svg>\n   107\t        Google でログイン\n   108\t      </button>\n   109\t      <p class=\"login-error\" id=\"loginError\">@gokkoclub.jp のメールアドレスでログインしてください</p>\n   110\t    </div>\n   111\t    <p class=\"login-domain\">@gokkoclub.jp のメールアドレスが必要です</p>\n   112\t  </div>\n   113\t</div>\n   114\t\n   115\t<!-- ── App Content (hidden until login) ── -->\n   116\t<div class=\"app-content\" id=\"appContent\">\n   117\t\n   118\t<!-- ── Hero ── -->\n   119\t<section class=\"hero\">\n   120\t  <div class=\"hero-badge\">GOKKO Inc. — Advertising Menu <span class=\"menu-year\"></span></div>\n   121\t  <h1>Ad Pricing<br>Simulator</h1>\n   122\t  <p>縦型ショートドラマ広告利用の料金を、プランと各係数からリアルタイムでシミュレーション</p>\n   123\t\n   124\t  <div class=\"plan-selector\" id=\"planSelector\" role=\"radiogroup\" aria-label=\"プラン選択\">\n   125\t    <div class=\"plan-btn\" data-plan=\"0\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n   126\t      <span class=\"plan-num\">PLAN 01</span>\n   127\t      <span class=\"plan-name\">ライトプラン</span>\n   128\t      <span class=\"plan-sub\">フック重視</span>\n   129\t    </div>\n   130\t    <div class=\"plan-btn\" data-plan=\"1\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n   131\t      <span class=\"plan-num\">PLAN 02</span>\n   132\t      <span class=\"plan-name\">ベーシックプラン</span>\n   133\t      <span class=\"plan-sub\">実稼働費回収</span>\n   134\t    </div>\n   135\t    <div class=\"plan-btn active\" data-plan=\"2\" role=\"radio\" aria-checked=\"true\" tabindex=\"0\">\n   136\t      <span class=\"plan-recommended\">RECOMMENDED</span>\n   137\t      <span class=\"plan-num\">PLAN 03</span>\n   138\t      <span class=\"plan-name\">スタンダードプラン</span>\n   139\t      <span class=\"plan-sub\">バランス型</span>\n   140\t    </div>\n   141\t    <div class=\"plan-btn\" data-plan=\"3\" role=\"radio\" aria-checked=\"false\" tabindex=\"0\">\n   142\t      <span class=\"plan-num\">PLAN 04</span>\n   143\t      <span class=\"plan-name\">プレミアムプラン</span>\n   144\t      <span class=\"plan-sub\">アップセル</span>\n   145\t    </div>\n   146\t  </div>\n   147\t</section>\n   148\t\n   149\t<!-- ── Formula Bar ── -->\n   150\t<div class=\"formula-bar\">\n   151\t  <span>総額</span> = 基本出演料 × 使用期間 × 競合排除 × 業界 × メディア × 出演者ランク × マージン\n   152\t</div>\n   153\t\n   154\t<!-- ── Main ── -->\n   155\t<div class=\"container\">\n   156\t\n   157\t  <!-- Base Fee -->\n   158\t  <section class=\"section\">\n   159\t    <div class=\"section-label\">Base Fee</div>\n   160\t    <div class=\"section-title\">基本出演料を入力</div>\n   161\t    <div class=\"base-fee-card\">\n   162\t      <label>ショートドラマ出演時のキャスティング費（税別）</label>\n   163\t      <div class=\"input-row\">\n   164\t        <span>¥</span>\n   165\t        <input type=\"text\" class=\"base-fee-input\" id=\"baseFee\" placeholder=\"100,000\" value=\"100,000\" inputmode=\"numeric\" aria-label=\"基本出演料\">\n   166\t      </div>\n   167\t    </div>\n   168\t  </section>\n   169\t\n   170\t  <!-- Coefficients -->\n   171\t  <section class=\"section\">\n   172\t    <div class=\"section-label\">Coefficients</div>\n   173\t    <div class=\"section-title\">各係数を選択してください</div>\n   174\t    <div class=\"coeff-grid\" id=\"coeffGrid\"></div>\n   175\t  </section>\n   176\t\n   177\t  <!-- Reference -->\n   178\t  <section class=\"section\">\n   179\t    <div class=\"section-label\">Reference</div>\n   180\t    <div class=\"section-title\">出演者ランク別 基本出演料の目安</div>\n   181\t    <div class=\"ref-table-wrap\">\n   182\t      <table class=\"ref-table\">\n   183\t        <thead>\n   184\t          <tr><th>ランク</th><th>係数</th><th>説明</th><th>基本出演料目安</th></tr>\n   185\t        </thead>\n   186\t        <tbody>\n   187\t          <tr><td>新人A</td><td>×0.8</td><td>GOKKO専属新人</td><td>5万円</td></tr>\n   188\t          <tr><td>新人B</td><td>×1.0</td><td>一般新人キャスト</td><td>8〜12万円</td></tr>\n   189\t          <tr><td>準中堅</td><td>×1.8</td><td>実績ある若手</td><td>15〜25万円</td></tr>\n   190\t          <tr><td>中堅A</td><td>×2.5</td><td>中堅タレント</td><td>30〜40万円</td></tr>\n   191\t          <tr><td>中堅B</td><td>×3.5</td><td>人気中堅タレント</td><td>50〜80万円</td></tr>\n   192\t          <tr><td>準有名</td><td>×5.0</td><td>知名度上昇中</td><td>80〜120万円</td></tr>\n   193\t          <tr><td>有名A</td><td>×8.0</td><td>有名タレント</td><td>150〜300万円</td></tr>\n   194\t          <tr><td>有名S</td><td>×12.0</td><td>トップクラス</td><td>500万円以上</td></tr>\n   195\t        </tbody>\n   196\t      </table>\n   197\t    </div>\n   198\t  </section>\n   199\t</div>\n   200\t\n   201\t<!-- ── Sticky Result ── -->\n   202\t<div class=\"result-panel\" id=\"resultPanel\">\n   203\t  <div class=\"result-inner\">\n   204\t    <div class=\"result-left\">\n   205\t      <div class=\"result-plan-badge\" id=\"resultPlanBadge\">STANDARD</div>\n   206\t      <div class=\"result-breakdown\" id=\"resultBreakdown\"></div>\n   207\t    </div>\n   208\t    <div class=\"result-total\">\n   209\t      <div class=\"result-total-label\">Estimated Total</div>\n   210\t      <div class=\"result-total-value\" id=\"resultValue\" aria-live=\"polite\" aria-atomic=\"true\">¥0</div>\n   211\t    </div>\n   212\t  </div>\n   213\t  <div class=\"sr-only\" id=\"resultLiveRegion\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n   214\t</div>\n   215\t\n   216\t<!-- ── Footer ── -->\n   217\t<footer class=\"footer\">\n   218\t  © <span class=\"copyright-year\"></span> GOKKO Inc. All rights reserved. ｜ 本料金表は参考価格です。正式なお見積りは別途ご相談ください。\n   219\t</footer>\n   220\t\n   221\t</div><!-- /app-content -->\n   222\t\n   223\t<script>\n   224\t// ═══════════════════════════════════════\n   225\t// GOOGLE AUTH\n   226\t// ═══════════════════════════════════════\n   227\tconst GOOGLE_CLIENT_ID = '777058430626-nla9pd956ss4t7jrchf58ebc0u614rcq.apps.googleusercontent.com';\n   228\tconst ALLOWED_DOMAIN = 'gokkoclub.jp';\n   229\t\n   230\tfunction showApp() {\n   231\t  hideLoginError();\n   232\t  document.getElementById('loginOverlay').classList.add('hidden');\n   233\t  document.getElementById('appContent').classList.add('visible');\n   234\t}\n   235\t\n   236\tfunction showLoginError(message) {\n   237\t  const errorEl = document.getElementById('loginError');\n   238\t  errorEl.textContent = message;\n   239\t  errorEl.style.display = 'block';\n   240\t}\n   241\t\n   242\tfunction hideLoginError() {\n   243\t  document.getElementById('loginError').style.display = 'none';\n   244\t}\n   245\t\n   246\tfunction handleGoogleLogin() {\n   247\t  hideLoginError();\n   248\t  try {\n   249\t    const client = google.accounts.oauth2.initTokenClient({\n   250\t      client_id: GOOGLE_CLIENT_ID,\n   251\t      scope: 'email profile',\n   252\t      callback: (response) => {\n   253\t        if (response.error) {\n   254\t          showLoginError('Googleログインに失敗しました。再度お試しください。');\n   255\t          return;\n   256\t        }\n   257\t        if (response.access_token) {\n   258\t          verifyAndShowApp(response.access_token);\n   259\t        }\n   260\t      },\n   261\t    });\n   262\t    client.requestAccessToken();\n   263\t  } catch(e) {\n   264\t    console.error('Google Auth error:', e);\n   265\t    alert('Googleログインの読み込みに失敗しました。https:// でアクセスしてください。');\n   266\t  }\n   267\t}\n   268\t\n   269\tfunction verifyAndShowApp(accessToken) {\n   270\t  fetch('https://www.googleapis.com/oauth2/v3/userinfo', {\n   271\t    headers: { Authorization: 'Bearer ' + accessToken }\n   272\t  })\n   273\t  .then(r => {\n   274\t    if (!r.ok) throw new Error('userinfo request failed: ' + r.status);\n   275\t    return r.json();\n   276\t  })\n   277\t  .then(user => {\n   278\t    if (user.email && user.email.endsWith('@' + ALLOWED_DOMAIN)) {\n   279\t      sessionStorage.setItem('gokko_access_token', accessToken);\n   280\t      showApp();\n   281\t    } else {\n   282\t      sessionStorage.removeItem('gokko_access_token');\n   283\t      showLoginError('@gokkoclub.jp のメールアドレスでログインしてください');\n   284\t    }\n   285\t  })\n   286\t  .catch(err => {\n   287\t    console.error('Auth verification failed:', err);\n   288\t    sessionStorage.removeItem('gokko_access_token');\n   289\t    showLoginError('ログイン状態を確認できませんでした。再度ログインしてください。');\n   290\t  });\n   291\t}\n   292\t\n   293\twindow.addEventListener('DOMContentLoaded', () => {\n   294\t  document.getElementById('googleLoginBtn').addEventListener('click', handleGoogleLogin);\n   295\t  const savedToken = sessionStorage.getItem('gokko_access_token');\n   296\t  if (savedToken) {\n   297\t    verifyAndShowApp(savedToken);\n   298\t  }\n   299\t});\n   300\t</script>\n   301\t<script src=\"shared.js\"></script>\n   302\t<script>\n   303\ttry {\n   304\t  initSimulator();\n   305\t} catch(e) {\n   306\t  console.error('❌ 初期化エラー:', e);\n   307\t}\n   308\t</script>\n   309\t</body>\n   310\t</html>\n","exit_code":0,"status":"completed"}}
