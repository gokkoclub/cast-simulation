\t    media: [\n   148\t      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n   149\t      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n   150\t      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n   151\t      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n   152\t      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n   153\t      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n   154\t      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n   155\t      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n   156\t    ],\n   157\t    mediaCap: 3.0,\n   158\t  },\n   159\t];\n   160\t\n   161\t// GOKKO Margin is shared across all plans (3 tiers)\n   162\tconst MARGIN = [\n   163\t  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n   164\t  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n   165\t  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n   166\t];\n   167\t\n   168\t// Talent rank is shared across all plans\n   169\tconst RANK = [\n   170\t  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n   171\t  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n   172\t  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n   173\t  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n   174\t  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n   175\t  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n   176\t  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n   177\t  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n   178\t];\n   179\t\n   180\t// ═══════════════════════════════════════\n   181\t// STATE\n   182\t// ═══════════════════════════════════════\n   183\tlet currentPlan = 2; // default: スタンダード\n   184\tconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n   185\t\n   186\t// ═══════════════════════════════════════\n   187\t// YEAR SYNC\n   188\t// ═══════════════════════════════════════\n   189\tfunction syncCurrentYear() {\n   190\t  const y = String(new Date().getFullYear());\n   191\t  document.querySelectorAll('.copyright-year').forEach(el => { el.textContent = y; });\n   192\t  document.querySelectorAll('.menu-year').forEach(el => { el.textContent = y; });\n   193\t}\n   194\t\n   195\t// ═══════════════════════════════════════\n   196\t// PLAN SELECTOR\n   197\t// ═══════════════════════════════════════\n   198\tfunction selectPlan(btn) {\n   199\t  currentPlan = parseInt(btn.dataset.plan, 10);\n   200\t  document.querySelectorAll('.plan-btn').forEach(b => {\n   201\t    b.classList.remove('active');\n   202\t    b.setAttribute('aria-checked', 'false');\n   203\t  });\n   204\t  btn.classList.add('active');\n   205\t  btn.setAttribute('aria-checked', 'true');\n   206\t  state.period = 0; state.competition = 0; state.industry = 0; state.media = [0]; state.rank = 0; state.margin = 0;\n   207\t  renderCards();\n   208\t  calculate();\n   209\t}\n   210\t\n   211\t// ═══════════════════════════════════════\n   212\t// RENDER\n   213\t// ═══════════════════════════════════════\n   214\tfunction getCoeffCategories() {\n   215\t  const plan = PLANS[currentPlan];\n   216\t  return [\n   217\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n   218\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n   219\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n   220\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n   221\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n   222\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n   223\t  ];\n   224\t}\n   225\t\n   226\tfunction renderCards() {\n   227\t  const grid = document.getElementById('coeffGrid');\n   228\t  grid.innerHTML = '';\n   229\t  const cats = getCoeffCategories();\n   230\t\n   231\t  cats.forEach(cat => {\n   232\t    const card = document.createElement('div');\n   233\t    card.className = 'coeff-card';\n   234\t    const isCheck = cat.type === 'checkbox';\n   235\t\n   236\t    let html = '';\n   237\t    cat.options.forEach((opt, i) => {\n   238\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n   239\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n   240\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `\\u00d7${opt.coeff}`;\n   241\t      const role = isCheck ? 'checkbox' : 'radio';\n   242\t      const ariaChecked = sel ? 'true' : 'false';\n   243\t      const ariaDisabled = opt.base ? 'true' : 'false';\n   244\t      const tabIndex = opt.base ? '-1' : '0';\n   245\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''} role=\"${role}\" aria-checked=\"${ariaChecked}\" aria-disabled=\"${ariaDisabled}\" tabindex=\"${tabIndex}\">\n   246\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n   247\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n   248\t    });\n   249\t\n   250\t    const capNote = cat.cap ? `<div class=\"media-note\">\\u203b \\u52a0\\u7b97\\u5408\\u8a08\\u306e\\u4e0a\\u9650\\uff08Cap\\uff09: \\u00d7${cat.cap}</div>` : '';\n   251\t    const groupRole = isCheck ? 'group' : 'radiogroup';\n   252\t\n   253\t    card.innerHTML = `<div class=\"coeff-header\">\n   254\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n   255\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\" role=\"${groupRole}\" aria-label=\"${cat.name}\">${html}</div>${capNote}`;\n   256\t\n   257\t    grid.appendChild(card);\n   258\t  });\n   259\t\n   260\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n","exit_code":0,"status":"completed"}}
