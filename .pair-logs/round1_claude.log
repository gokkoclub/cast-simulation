\n<!-- ── Footer ── -->\n<footer class=\"footer\">\n  © 2025 GOKKO Inc. All rights reserved. ｜ 本料金表は参考価格です。正式なお見積りは別途ご相談ください。\n</footer>\n\n</div><!-- /app-content -->\n\n<script>\n// ═══════════════════════════════════════\n// GOOGLE AUTH\n// ═══════════════════════════════════════\n// ★★★ ここにGoogle Cloud ConsoleのクライアントIDを入れてください ★★★\nconst GOOGLE_CLIENT_ID = '777058430626-nla9pd956ss4t7jrchf58ebc0u614rcq.apps.googleusercontent.com';\nconst ALLOWED_DOMAIN = 'gokkoclub.jp';\n\nfunction handleGoogleLogin() {\n  try {\n    const client = google.accounts.oauth2.initTokenClient({\n      client_id: GOOGLE_CLIENT_ID,\n      scope: 'email profile',\n      callback: (response) => {\n        if (response.access_token) {\n          fetch('https://www.googleapis.com/oauth2/v3/userinfo', {\n            headers: { Authorization: 'Bearer ' + response.access_token }\n          })\n          .then(r => r.json())\n          .then(user => {\n            if (user.email && user.email.endsWith('@' + ALLOWED_DOMAIN)) {\n              document.getElementById('loginOverlay').classList.add('hidden');\n              document.getElementById('appContent').classList.add('visible');\n              sessionStorage.setItem('gokko_user', JSON.stringify({\n                email: user.email,\n                name: user.name,\n                picture: user.picture\n              }));\n            } else {\n              document.getElementById('loginError').style.display = 'block';\n            }\n          });\n        }\n      },\n    });\n    client.requestAccessToken();\n  } catch(e) {\n    console.error('Google Auth error:', e);\n    alert('Googleログインの読み込みに失敗しました。https:// でアクセスしてください。');\n  }\n}\n\n// Check existing session\nwindow.addEventListener('DOMContentLoaded', () => {\n  const saved = sessionStorage.getItem('gokko_user');\n  if (saved) {\n    document.getElementById('loginOverlay').classList.add('hidden');\n    document.getElementById('appContent').classList.add('visible');\n  }\n});\n</sc