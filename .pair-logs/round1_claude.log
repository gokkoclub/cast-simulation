,  coeff: 2.5,  desc: '中堅タレント' },\n737\t  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n738\t  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n739\t  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n740\t  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n741\t];\n742\t\n743\t// ═══════════════════════════════════════\n744\t// STATE\n745\t// ═══════════════════════════════════════\n746\tlet currentPlan = 2; // default: スタンダード\n747\tconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n748\t\n749\t// ═══════════════════════════════════════\n750\t// PLAN SELECTOR\n751\t// ═══════════════════════════════════════\n752\tdocument.querySelectorAll('.plan-btn').forEach(btn => {\n753\t  btn.addEventListener('click', () => {\n754\t    currentPlan = parseInt(btn.dataset.plan);\n755\t    document.querySelectorAll('.plan-btn').forEach(b => b.classList.remove('active'));\n756\t    btn.classList.add('active');\n757\t    // Reset selections\n758\t    state.period = 0; state.competition = 0; state.industry = 0; state.media = [0]; state.rank = 0; state.margin = 0;\n759\t    renderCards();\n760\t    calculate();\n761\t  });\n762\t});\n763\t\n764\t// ═══════════════════════════════════════\n765\t// RENDER\n766\t// ═══════════════════════════════════════\n767\tfunction getCoeffCategories() {\n768\t  const plan = PLANS[currentPlan];\n769\t  return [\n770\t    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n771\t    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n772\t    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n773\t    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n774\t    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n775\t    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n776\t  ];\n777\t}\n778\t\n779\tfunction renderCards() {\n780\t  const grid = document.getElementById('coeffGrid');\n781\t  grid.innerHTML = '';\n782\t  const cats = getCoeffCategories();\n783\t\n784\t  cats.forEach(cat => {\n785\t    const card = document.createElement('div');\n786\t    card.className = 'coeff-card';\n787\t    const isCheck = cat.type === 'checkbox';\n788\t\n789\t    let html = '';\n790\t    cat.options.forEach((opt, i) => {\n791\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n792\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n793\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n794\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''}>\n795\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n796\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n797\t    });\n798\t\n799\t    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n800\t\n801\t    card.innerHTML = `<div class=\"coeff-header\">\n802\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n803\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\">${html}</div>${capNote}`;\n804\t\n805\t    grid.appendChild(card);\n806\t  });\n807\t\n808\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n809\t    el.addEventListener('click', handleClick);\n810\t  });\n811\t}\n812\t\n813\tfunction handleClick(e) {\n814\t  const el = e.currentTarget;\n815\t  const catId = el.dataset.cat;\n816\t  const idx = parseInt(el.dataset.idx);\n817\t  const cats = getCoeffCategories();\n818\t  const cat = cats.find(c => c.id === catId);\n819\t\n820\t  if (cat.type === 'checkbox') {\n821\t    if (el.dataset.base) return;\n822\t    const a = state[catId];\n823\t    const p = a.indexOf(idx);\n824\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n825\t  } else {\n826\t    state[catId] = idx;\n827\t  }\n828\t  renderCards();\n829\t  calculate();\n830\t}\n831\t\n832\t// ═══════════════════════════════════════\n833\t// CALCULATE\n834\t// ═══════════════════════════════════════\n835\tfunction calculate() {\n836\t  const plan = PLANS[currentPlan];\n837\t  const cats = getCoeffCategories();\n838\t  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n839\t\n840\t  const pCoeff = plan.period[state.period].coeff;\n841\t  const cCoeff = plan.competition[state.competition].coeff;\n842\t  const iCoeff = plan.industry[state.industry].coeff;\n843\t\n844\t  let mSum = 0;\n845\t  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n846\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n847\t\n848\t  const rCoeff = RANK[state.rank].coeff;\n849\t  const marginCoeff = MARGIN[state.margin].coeff;\n850\t\n851\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n852\t\n853\t  // Badge\n854\t  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n855\t\n856\t  // Breakdown\n857\t  const bd = document.getElementById('resultBreakdown');\n858\t  const chips = [\n859\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },"}]},"parent_tool_use_id":null,"session_id":"fa66a8e6-4850-48ec-b41f-51523c6e87cd","uuid":"20bb7a8a-6d47-45cc-8b0e-0079b74f9397","timestamp":"2026-04-09T09:25:46.363Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ucmuller/workspace/cast-simulation/gokko-ad-pricing-preview.html","content":"      { label: '商品競合のみ', coeff: 1.5, desc: '同一商品カテゴリを排除' },\n      { label: '業界競合',     coeff: 2.0, desc: '同一業界全体を排除' },\n      { label: '全競合排除',   coeff: 2.5, desc: 'すべての競合を排除' },\n    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲