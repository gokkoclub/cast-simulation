HTML = '';\n930\t  const cats = getCoeffCategories();\n931\t\n932\t  cats.forEach(cat => {\n933\t    const card = document.createElement('div');\n934\t    card.className = 'coeff-card';\n935\t    const isCheck = cat.type === 'checkbox';\n936\t\n937\t    let html = '';\n938\t    cat.options.forEach((opt, i) => {\n939\t      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n940\t      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n941\t      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n942\t      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''}>\n943\t        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n944\t        <div class=\"opt-coeff\">${cv}</div></div>`;\n945\t    });\n946\t\n947\t    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n948\t\n949\t    card.innerHTML = `<div class=\"coeff-header\">\n950\t      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n951\t    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\">${html}</div>${capNote}`;\n952\t\n953\t    grid.appendChild(card);\n954\t  });\n955\t\n956\t  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n957\t    el.addEventListener('click', handleClick);\n958\t  });\n959\t}\n960\t\n961\tfunction handleClick(e) {\n962\t  const el = e.currentTarget;\n963\t  const catId = el.dataset.cat;\n964\t  const idx = parseInt(el.dataset.idx);\n965\t  const cats = getCoeffCategories();\n966\t  const cat = cats.find(c => c.id === catId);\n967\t\n968\t  if (cat.type === 'checkbox') {\n969\t    if (el.dataset.base) return;\n970\t    const a = state[catId];\n971\t    const p = a.indexOf(idx);\n972\t    p > -1 ? a.splice(p, 1) : a.push(idx);\n973\t  } else {\n974\t    state[catId] = idx;\n975\t  }\n976\t  renderCards();\n977\t  calculate();\n978\t}\n979\t\n980\t// ═══════════════════════════════════════\n981\t// CALCULATE\n982\t// ═══════════════════════════════════════\n983\tfunction calculate() {\n984\t  const plan = PLANS[currentPlan];\n985\t  const cats = getCoeffCategories();\n986\t  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n987\t\n988\t  const pCoeff = plan.period[state.period].coeff;\n989\t  const cCoeff = plan.competition[state.competition].coeff;\n990\t  const iCoeff = plan.industry[state.industry].coeff;\n991\t\n992\t  let mSum = 0;\n993\t  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n994\t  const mCoeff = Math.min(mSum, plan.mediaCap);\n995\t\n996\t  const rCoeff = RANK[state.rank].coeff;\n997\t  const marginCoeff = MARGIN[state.margin].coeff;\n998\t\n999\t  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n1000\t\n1001\t  // Badge\n1002\t  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n1003\t\n1004\t  // Breakdown\n1005\t  const bd = document.getElementById('resultBreakdown');\n1006\t  const chips = [\n1007\t    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n1008\t    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n1009\t  ];\n1010\t  bd.innerHTML = chips.map((c, i) =>\n1011\t    `<span class=\"result-chip\">${c.l} <span>×${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">×</span>' : ''}`\n1012\t  ).join('');\n1013\t\n1014\t  document.getElementById('resultValue').textContent = '¥' + Math.round(total).toLocaleString('ja-JP');\n1015\t}\n1016\t\n1017\t// ═══════════════════════════════════════\n1018\t// INPUT FORMAT\n1019\t// ═══════════════════════════════════════\n1020\tdocument.getElementById('baseFee').addEventListener('input', function() {\n1021\t  let raw = this.value.replace(/[^0-9]/g, '');\n1022\t  if (raw) this.value = parseInt(raw).toLocaleString('ja-JP');\n1023\t  calculate();\n1024\t});\n1025\t\n1026\t// ═══════════════════════════════════════\n1027\t// INIT\n1028\t// ═══════════════════════════════════════\n1029\ttry {\n1030\t  renderCards();\n1031\t  calculate();\n1032\t  console.log('✅ 初期化完了: カード数 =', document.querySelectorAll('.coeff-card').length);\n1033\t} catch(e) {\n1034\t  console.error('❌ 初期化エラー:', e);\n1035\t}\n1036\t</script>\n1037\t</body>\n1038\t</html>\n1039\t"}]},"parent_tool_use_id":null,"session_id":"fa66a8e6-4850-48ec-b41f-51523c6e87cd","uuid":"03ee1350-0a81-4a4e-89b9-82f84c4907e9","timestamp":"2026-04-09T09:22:48.651Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ucmuller/workspace/cast-simulation/index.html","content":"    ],\n    industry: [\n      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n      { label: '食品・飲料',           coeff: 1.3, desc: '頻繁な広告展開が想定' },\n      { label: '化粧品・美容',         coeff: 1.6, desc: 'イメージ重視で高額予算' },\n      { label: '金融・保険',           coeff: 2.0, desc: '規制業界で慎重な選定が必要' },\n      { label: '医療・薬品',           coeff: 2.5, desc: '最高レベルの信頼性が要求' },\n      { label: 'アルコール・ギャンブル', coeff: 3.0, desc: '特殊な規制対象業界' },\n    ],\n    media: [\n      { label: 'TikTok（基本）',       coeff: 1.0, desc: '基本配信面', base: true },\n      { label: 'Instagram',           coeff: 0.3, desc: 'TikTokに加算' },\n      { label: 'YouTube（Short含む）', coeff: 0.4, desc: 'TikTokに加算' },\n      { label: 'X（旧Twitter）',       coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'LINE VOOM',           coeff: 0.2, desc: 'TikTokに加算' },\n      { label: 'バナー（静止画）',     coeff: 0.1, desc: 'TikTokに加算' },\n      { label: 'Web広告（HP埋込等）',  coeff: 0.5, desc: 'TikTokに加算' },\n      { label: 'テレビCM',            coeff: 0.6, desc: 'TikTokに加算' },\n    ],\n    mediaCap: 3.0,\n  },\n];\n\n// GOKKO Margin is shared across all plans (3 tiers)\nconst MARGIN = [\n  { label: 'ライト',      coeff: 1.0, desc: 'マージンなし' },\n  { label: 'スタンダード', coeff: 1.2, desc: '標準マージン' },\n  { label: 'フル',        coeff: 1.5, desc: 'フルサポート込み' },\n];\n\n// Talent rank is shared across all plans\nconst RANK = [\n  { label: '新人A',  coeff: 0.8,  desc: 'GOKKO専属新人' },\n  { label: '新人B',  coeff: 1.0,  desc: '一般新人キャスト' },\n  { label: '準中堅', coeff: 1.8,  desc: '実績ある若手' },\n  { label: '中堅A',  coeff: 2.5,  desc: '中堅タレント' },\n  { label: '中堅B',  coeff: 3.5,  desc: '人気中堅タレント' },\n  { label: '準有名', coeff: 5.0,  desc: '知名度上昇中' },\n  { label: '有名A',  coeff: 8.0,  desc: '有名タレント' },\n  { label: '有名S',  coeff: 12.0, desc: 'トップクラス' },\n];\n\n// ═══════════════════════════════════════\n// STATE\n// ═══════════════════════════════════════\nlet currentPlan = 2; // default: スタンダード\nconst state = { period: 0, competition: 0, industry: 0, media: [0], rank: 0, margin: 0 };\n\n// ═══════════════════════════════════════\n// PLAN SELECTOR\n// ═══════════════════════════════════════\ndocument.querySelectorAll('.plan-btn').forEach(btn => {\n  btn.addEventListener('click', () => {\n    currentPlan = parseInt(btn.dataset.plan);\n    document.querySelectorAll('.plan-btn').forEach(b => b.classList.remove('active'));\n    btn.classList.add('active');\n    // Reset selections\n    state.period = 0; state.competition = 0; state.industry = 0; state.media = [0]; state.rank = 0; state.margin = 0;\n    renderCards();\n    calculate();\n  });\n});\n\n// ═══════════════════════════════════════\n// RENDER\n// ═══════════════════════════════════════\nfunction getCoeffCategories() {\n  const plan = PLANS[currentPlan];\n  return [\n    { id: 'period',      num: '01', name: '使用期間',      type: 'radio',    options: plan.period },\n    { id: 'competition', num: '02', name: '競合排除',      type: 'radio',    options: plan.competition },\n    { id: 'industry',    num: '03', name: '業界',          type: 'radio',    options: plan.industry },\n    { id: 'media',       num: '04', name: 'メディア展開',  type: 'checkbox', options: plan.media, cap: plan.mediaCap },\n    { id: 'rank',        num: '05', name: '出演者ランク',  type: 'radio',    options: RANK },\n    { id: 'margin',      num: '06', name: 'GOKKOマージン', type: 'radio',    options: MARGIN },\n  ];\n}\n\nfunction renderCards() {\n  const grid = document.getElementById('coeffGrid');\n  grid.innerHTML = '';\n  const cats = getCoeffCategories();\n\n  cats.forEach(cat => {\n    const card = document.createElement('div');\n    card.className = 'coeff-card';\n    const isCheck = cat.type === 'checkbox';\n\n    let html = '';\n    cat.options.forEach((opt, i) => {\n      const sel = isCheck ? state[cat.id].includes(i) : state[cat.id] === i;\n      const cls = `${isCheck ? 'media-option' : 'coeff-option'}${sel ? ' selected' : ''}`;\n      const cv = isCheck && !opt.base ? `+${opt.coeff}` : `×${opt.coeff}`;\n      html += `<div class=\"${cls}\" data-cat=\"${cat.id}\" data-idx=\"${i}\" ${opt.base ? 'data-base=\"true\"' : ''}>\n        <div class=\"opt-left\"><div class=\"opt-label\">${opt.label}</div><div class=\"opt-desc\">${opt.desc}</div></div>\n        <div class=\"opt-coeff\">${cv}</div></div>`;\n    });\n\n    const capNote = cat.cap ? `<div class=\"media-note\">※ 加算合計の上限（Cap）: ×${cat.cap}</div>` : '';\n\n    card.innerHTML = `<div class=\"coeff-header\">\n      <div class=\"coeff-number\">${cat.num}</div><div class=\"coeff-name\">${cat.name}</div>\n    </div><div class=\"${isCheck ? 'media-options' : 'coeff-options'}\">${html}</div>${capNote}`;\n\n    grid.appendChild(card);\n  });\n\n  grid.querySelectorAll('.coeff-option, .media-option').forEach(el => {\n    el.addEventListener('click', handleClick);\n  });\n}\n\nfunction handleClick(e) {\n  const el = e.currentTarget;\n  const catId = el.dataset.cat;\n  const idx = parseInt(el.dataset.idx);\n  const cats = getCoeffCategories();\n  const cat = cats.find(c => c.id === catId);\n\n  if (cat.type === 'checkbox') {\n    if (el.dataset.base) return;\n    const a = state[catId];\n    const p = a.indexOf(idx);\n    p > -1 ? a.splice(p, 1) : a.push(idx);\n  } else {\n    state[catId] = idx;\n  }\n  renderCards();\n  calculate();\n}\n\n// ═══════════════════════════════════════\n// CALCULATE\n// ═══════════════════════════════════════\nfunction calculate() {\n  const plan = PLANS[currentPlan];\n  const cats = getCoeffCategories();\n  const baseFee = parseInt(document.getElementById('baseFee').value.replace(/[^0-9]/g, '')) || 0;\n\n  const pCoeff = plan.period[state.period].coeff;\n  const cCoeff = plan.competition[state.competition].coeff;\n  const iCoeff = plan.industry[state.industry].coeff;\n\n  let mSum = 0;\n  state.media.forEach(i => { mSum += plan.media[i].coeff; });\n  const mCoeff = Math.min(mSum, plan.mediaCap);\n\n  const rCoeff = RANK[state.rank].coeff;\n  const marginCoeff = MARGIN[state.margin].coeff;\n\n  const total = baseFee * pCoeff * cCoeff * iCoeff * mCoeff * rCoeff * marginCoeff;\n\n  // Badge\n  document.getElementById('resultPlanBadge').textContent = plan.nameEn;\n\n  // Breakdown\n  const bd = document.getElementById('resultBreakdown');\n  const chips = [\n    { l: '期間', v: pCoeff }, { l: '競合', v: cCoeff }, { l: '業界', v: iCoeff },\n    { l: 'メディア', v: mCoeff }, { l: 'ランク', v: rCoeff }, { l: 'マージン', v: marginCoeff },\n  ];\n  bd.innerHTML = chips.map((c, i) =>\n    `<span class=\"result-chip\">${c.l} <span>×${c.v}</span></span>${i < chips.length - 1 ? '<span class=\"result-multiply\">×</span>' : ''}`\n  ).join('');\n\n  document.getElementById('resultValue').textContent = '¥' + Math.round(total).toLocaleString('ja-JP');\n}\n\n// ═══════════════════════════════════════\n// INPUT FORMAT\n// ═══════════════════════════════════════\ndocument.getElementById('baseFee').addEventListener('input', function() {\n  let raw = this.value.replace(/[^0-9]/g, '');\n  if (raw) this.value = parseInt(raw).toLocaleString('ja-JP');\n  calculate();\n});\n\n// ═══════════════════════════════════════\n// INIT\n// ═══════════════════════════════════════\ntry {\n  renderCards();\n  calculate();\n  console.log('✅ 初期化完了: カード数 =', document.querySelectorAll('.coeff-card').length);\n} catch(e) {\n  console.error('❌ 初期化エラー:', e);\n}\n</script>\n</body>\n</html>\n","numLines":191,"startLine":849,"totalLines":1039}}}
