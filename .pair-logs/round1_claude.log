{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016MFgJwgcjsQqBvJX1Q1PKL","type":"tool_result","content":"600\t    <div class=\"base-fee-card\">\n601\t      <label>ショートドラマ出演時のキャスティング費（税別）</label>\n602\t      <div class=\"input-row\">\n603\t        <span>¥</span>\n604\t        <input type=\"text\" class=\"base-fee-input\" id=\"baseFee\" placeholder=\"100,000\" value=\"100,000\">\n605\t      </div>\n606\t    </div>\n607\t  </section>\n608\t\n609\t  <!-- Coefficients -->\n610\t  <section class=\"section\">\n611\t    <div class=\"section-label\">Coefficients</div>\n612\t    <div class=\"section-title\">各係数を選択してください</div>\n613\t    <div class=\"coeff-grid\" id=\"coeffGrid\"></div>\n614\t  </section>\n615\t\n616\t  <!-- Reference -->\n617\t  <section class=\"section\">\n618\t    <div class=\"section-label\">Reference</div>\n619\t    <div class=\"section-title\">出演者ランク別 基本出演料の目安</div>\n620\t    <div class=\"ref-table-wrap\">\n621\t      <table class=\"ref-table\">\n622\t        <thead>\n623\t          <tr><th>ランク</th><th>係数</th><th>説明</th><th>基本出演料目安</th></tr>\n624\t        </thead>\n625\t        <tbody>\n626\t          <tr><td>新人A</td><td>×0.8</td><td>GOKKO専属新人</td><td>5万円</td></tr>\n627\t          <tr><td>新人B</td><td>×1.0</td><td>一般新人キャスト</td><td>8〜12万円</td></tr>\n628\t          <tr><td>準中堅</td><td>×1.8</td><td>実績ある若手</td><td>15〜25万円</td></tr>\n629\t          <tr><td>中堅A</td><td>×2.5</td><td>中堅タレント</td><td>30〜40万円</td></tr>\n630\t          <tr><td>中堅B</td><td>×3.5</td><td>人気中堅タレント</td><td>50〜80万円</td></tr>\n631\t          <tr><td>準有名</td><td>×5.0</td><td>知名度上昇中</td><td>80〜120万円</td></tr>\n632\t          <tr><td>有名A</td><td>×8.0</td><td>有名タレント</td><td>150〜300万円</td></tr>\n633\t          <tr><td>有名S</td><td>×12.0</td><td>トップクラス</td><td>500万円以上</td></tr>\n634\t        </tbody>\n635\t      </table>\n636\t    </div>\n637\t  </section>\n638\t</div>\n639\t\n640\t<!-- ── Sticky Result ── -->\n641\t<div class=\"result-panel\" id=\"resultPanel\">\n642\t  <div class=\"result-inner\">\n643\t    <div class=\"result-left\">\n644\t      <div class=\"result-plan-badge\" id=\"resultPlanBadge\">STANDARD</div>\n645\t      <div class=\"result-breakdown\" id=\"resultBreakdown\"></div>\n646\t    </div>\n647\t    <div class=\"result-total\">\n648\t      <div class=\"result-total-label\">Estimated Total</div>\n649\t      <div class=\"result-total-value\" id=\"resultValue\">¥0</div>\n650\t    </div>\n651\t  </div>\n652\t</div>\n653\t\n654\t<!-- ── Footer ── -->\n655\t<footer class=\"footer\">\n656\t  © 2025 GOKKO Inc. All rights reserved. ｜ 本料金表は参考価格です。正式なお見積りは別途ご相談ください。\n657\t</footer>\n658\t\n659\t</div><!-- /app-content -->\n660\t\n661\t<script>\n662\t// ═══════════════════════════════════════\n663\t// GOOGLE AUTH\n664\t// ═══════════════════════════════════════\n665\t// ★★★ ここにGoogle Cloud ConsoleのクライアントIDを入れてください ★★★\n666\tconst GOOGLE_CLIENT_ID = '777058430626-nla9pd956ss4t7jrchf58ebc0u614rcq.apps.googleusercontent.com';\n667\tconst ALLOWED_DOMAIN = 'gokkoclub.jp';\n668\t\n669\tfunction handleGoogleLogin() {\n670\t  try {\n671\t    const client = google.accounts.oauth2.initTokenClient({\n672\t      client_id: GOOGLE_CLIENT_ID,\n673\t      scope: 'email profile',\n674\t      callback: (response) => {\n675\t        if (response.access_token) {\n676\t          fetch('https://www.googleapis.com/oauth2/v3/userinfo', {\n677\t            headers: { Authorization: 'Bearer ' + response.access_token }\n678\t          })\n679\t          .then(r => r.json())\n680\t          .then(user => {\n681\t            if (user.email && user.email.endsWith('@' + ALLOWED_DOMAIN)) {\n682\t              document.getElementById('loginOverlay').classList.add('hidden');\n683\t              document.getElementById('appContent').classList.add('visible');\n684\t              sessionStorage.setItem('gokko_user', JSON.stringify({\n685\t                email: user.email,\n686\t                name: user.name,\n687\t                picture: user.picture\n688\t              }));\n689\t            } else {\n690\t              document.getElementById('loginError').style.display = 'block';\n691\t            }\n692\t          });\n693\t        }\n694\t      },\n695\t    });\n696\t    client.requestAccessToken();\n697\t  } catch(e) {\n698\t    console.error('Google Auth error:', e);\n699\t    alert('Googleログインの読み込みに失敗しました。https:// でアクセスしてください。');\n700\t  }\n701\t}\n702\t\n703\t// Check existing session\n704\twindow.addEventListener('DOMContentLoaded', () => {\n705\t  const saved = sessionStorage.getItem('gokko_user');\n706\t  if (saved) {\n707\t    document.getElementById('loginOverlay').classList.add('hidden');\n708\t    document.getElementById('appContent').classList.add('visible');\n709\t  }\n710\t});\n711\t</script>\n712\t\n713\t<script>\n714\t// ═══════════════════════════════════════\n715\t// PLAN DATA — 4 plans × 5 coefficient categories\n716\t// ═══════════════════════════════════════\n717\tconst PLANS = [\n718\t  // ── PLAN 0: ライトプラン（フック重視）──\n719\t  {\n720\t    name: 'ライトプラン',\n721\t    nameEn: 'LIGHT',\n722\t    period: [\n723\t      { label: '1ヶ月', coeff: 0.8, desc: 'お試し配信' },\n724\t      { label: '3ヶ月', coeff: 1.0, desc: '短期集中キャンペーン' },\n725\t      { label: '6ヶ月', coeff: 1.3, desc: '標準的な広告契約' },\n726\t      { label: '1年',   coeff: 2.0, desc: '年間継続展開' },\n727\t      { label: '2年',   coeff: 3.0, desc: '長期ブランド戦略' },\n728\t      { label: '無期限', coeff: 4.0, desc: '恒久的な利用権' },\n729\t    ],\n730\t    competition: [\n731\t      { label: '競合なし',     coeff: 1.0, desc: '基本料金（ドラマと同条件）' },\n732\t      { label: '商品競合のみ', coeff: 1.3, desc: '同一商品カテゴリを排除' },\n733\t      { label: '業界競合',     coeff: 1.6, desc: '同一業界全体を排除' },\n734\t      { label: '全競合排除',   coeff: 2.0, desc: 'すべての競合を排除' },\n735\t    ],\n736\t    industry: [\n737\t      { label: '一般消費財',           coeff: 1.0, desc: '標準的な広告予算規模' },\n738\t      { label: '食品・飲料',           coeff: 1.1, desc: '頻繁な広告展開が想定' },\n739\t      { label: '化粧品・美容',         coeff: 1.3, desc: 'イメージ重視で高額