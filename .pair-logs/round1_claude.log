ont-weight: 600;\n    font-size: 12px;\n    letter-spacing: 0.5px;\n    white-space: nowrap;\n  }\n  .ref-table td {\n    padding: 11px 16px;\n    border-bottom: 1px solid var(--card-border);\n    color: var(--gray-700);\n  }\n  .ref-table tr:last-child td { border-bottom: none; }\n  .ref-table tr:hover td { background: var(--gray-100); }\n\n  /* ── Footer (Black) ── */\n  .footer {\n    background: var(--black);\n    color: rgba(255,255,255,0.3);\n    padding: 32px 24px;\n    text-align: center;\n    font-size: 11px;\n  }\n\n  /* ── Responsive ── */\n  @media (max-width: 768px) {\n    .hero { min-height: auto; padding: 48px 20px 36px; }\n    .hero h1 { font-size: 28px; }\n    .plan-selector { flex-direction: column; align-items: stretch; }\n    .plan-btn { min-width: unset; }\n    .coeff-grid { grid-template-columns: 1fr; gap: 14px; }\n    .result-inner { flex-direction: column; align-items: stretch; }\n    .result-left { justify-content: center; }\n    .result-total { text-align: center; }\n    .result-total-value { font-size: 24px; }\n    .section { padding: 40px 0; }\n    .section-title { font-size: 20px; margin-bottom: 28px; }\n  }\n\n  /* ── Animations ── */\n  @keyframes fadeUp {\n    from { opacity: 0; transform: translateY(16px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n  .coeff-card { animation: fadeUp 0.4s ease both; }\n  .coeff-card:nth-child(1) { animation-delay: 0.03s; }\n  .coeff-card:nth-child(2) { animation-delay: 0.06s; }\n  .coeff-card:nth-child(3) { animation-delay: 0.09s; }\n  .coeff-card:nth-child(4) { animation-delay: 0.12s; }\n  .coeff-card:nth-child(5) { animation-delay: 0.15s; }\n  .coeff-card:nth-child(6) { animation-delay: 0.18s; }\n\n  /* ── Login Overlay ── */\n  .login-overlay {\n    position: fixed;\n    inset: 0;\n    z-index: 9999;\n    background: var(--gray-100);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: opacity 0.4s, visibility 0.4s;\n  }\n  .login-overlay.hidden {\n    opacity: 0;\n    visibility: hidden;\n    pointer-events: none;\n  }\n  .login-card {\n    background: var(--white);\n    border-radius: 20px;\n    padding: 48px 40px;\n    text-align: center;\n    max-width: 400px;\n    width: 90%;\n    box-shadow: 0 2px 20px rgba(0,0,0,0.06);\n  }\n  .login-card h2 {\n    font-size: 26px;\n    font-weight: 900;\n    margin-bottom: 6px;\n    color: var(--black);\n  }\n  .login-card .login-sub {\n    font-size: 13px;\n    color: var(--gray-500);\n    margin-bottom: 32px;\n  }\n  .login-box {\n    background: var(--gray-100);\n    border-radius: 14px;\n    padding: 28px 24px;\n    margin-bottom: 20px;\n  }\n  .login-box p {\n    font-size: 13px;\n    color: var(--gray-600);\n    margin-bottom: 16px;\n  }\n  .google-btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    background: var(--white);\n    border: 1px solid var(--card-border);\n    border-radius: 10px;\n    padding: 12px 28px;\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--black);\n    cursor: pointer;\n    transition: all 0.2s;\n    font-family: var(--font-ja);\n  }\n  .google-btn:hover {\n    border-color: var(--gray-400);\n    box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n  }\n  .google-btn svg { width: 18px; height: 18px; }\n  .login-domain {\n    font-size: 12px;\n    color: var(--gray-400);\n  }\n  .login-error {\n    color: #d32f2f;\n    font-size: 12px;\n    margin-top: 12px;\n    display: none;\n  }\n\n  .app-content { display: none; }\n  .app-content.visible { display: block; }\n</style>\n</head>\n<body>\n\n<!-- ── Login Overlay ── -->\n<div class=\"login-overlay\" id=\"loginOverlay\">\n  <div class=\"login-card\">\n    <h2>広告料金シミュレーター</h2>\n    <p class=\"login-sub\">縦型ショートドラマ 広告利用メニュー</p>\n    <div class=\"login-box\">\n      <p>gokkoclub.jp のアカウントでログインしてください</p>\n      <button class=\"google-btn\" id=\"googleLoginBtn\" onclick=\"handleGoogleLogin()\">\n        <svg viewBox=\"0 0 48 48\"><path fill=\"#EA4335\" d=\"M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z\"/><path fill=\"#4285F4\" d=\"M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z\"/><path fill=\"#FBBC05\" d=\"M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z\"/><path fill=\"#34A853\" d=\"M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z\"/></svg>\n        Google でログイン\n      </button>\n      <p class=\"login-error\" id=\"loginError\">@gokkoclub.jp のメールアドレスでログインしてください</p>\n    </div>\n    <p class=\"login-domain\">@gokkoclub.jp のメールアドレスが必要です</p>\n  </div>\n</div>\n\n<!-- ── App Content (hidden until login) ── -->\n<div class=\"app-content\" id=\"appContent\">\n\n<!-- ── Hero ── -->\n<section class=\"hero\">\n  <div class=\"hero-badge\">GOKKO Inc. — Advertising Menu 2025</div>\n  <h1>Ad Pricing<br>Simulator</h1>\n  <p>縦型ショートドラマ広告利用の料金を、プランと各係数からリアルタイムでシミュレーション</p>\n\n  <div class=\"plan-selector\" id=\"planSelector\">\n    <div class=\"plan-btn\" data-plan=\"0\">\n      <span class=\"plan-num\">PLAN 01</span>\n      <span class=\"plan-name\">ライトプラン</span>\n      <span class=\"plan-sub\">フック重視</span>\n    </div>\n    <div class=\"plan-btn\" data-plan=\"1\">\n      <span class=\"plan-num\">PLAN 02</span>\n      <span class=\"plan-name\">ベーシックプラン</span>\n      <span class=\"plan-sub\">実稼働費回収</span>\n    </div>\n    <div class=\"plan-btn active\" data-plan=\"2\">\n      <span class=\"plan-recommended\">RECOMMENDED</span>\n      <span class=\"plan-num\">PLAN 03</span>\n      <span class=\"plan-name\">スタンダードプラン</span>\n      <span class=\"plan-sub\">バランス型</span>\n    </div>\n    <div class=\"plan-btn\" data-plan=\"3\">\n      <span class=\"plan-num\">PLAN 04</span>\n      <span class=\"plan-name\">プレミアムプラン</span>\n      <span class=\"plan-sub\">アップセル</span>\n    </div>\n  </div>\n</section>\n\n<!-- ── Formula Bar ── -->\n<div class=\"formula-bar\">\n  <span>総額</span> = 基本出演料 × 使用期間 × 競合排除 × 業界 × メディア × 出演者ランク × マージン\n</div>\n\n<!-- ── Main ── -->\n<div class=\"container\">\n\n  <!-- Base Fee -->\n  <section class=\"section\">\n    <div class=\"section-label\">Base Fee</div>\n    <div class=\"section-title\">基本出演料を入力</div>","numLines":200,"startLine":400,"totalLines":1039}}}
